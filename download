// ── QUIZ ──────────────────────────────────────────────────────
function Quiz({questions}){
  const cats=["All",...new Set(questions.map(q=>q.category))];
  const [cat,setCat]=useState("All");
  const [idx,setIdx]=useState(0);
  const [selected,setSelected]=useState(null);
  const [showExp,setShowExp]=useState(false);
  const [score,setScore]=useState({correct:0,total:0});
  const [finished,setFinished]=useState(false);
  const [shuffled,setShuffled]=useState(null);

  const pool=questions.filter(q=>cat==="All"||q.category===cat);

  const startQuiz=()=>{
    const sh=[...pool].sort(()=>Math.random()-0.5);
    setShuffled(sh);setIdx(0);setSelected(null);setShowExp(false);setScore({correct:0,total:0});setFinished(false);
  };

  if(!shuffled) return (
    <div style={{maxWidth:900,margin:"0 auto",padding:"24px 16px"}}>
      <h2 style={{color:C.gold,fontFamily:"Georgia,serif",marginBottom:16}}>Quiz Mode</h2>
      <div style={{display:"flex",flexWrap:"wrap",gap:6,marginBottom:20}}>
        {cats.map(c=> <button key={c} onClick={()=>setCat(c)} style={btnStyle(cat===c,false)}>{c}</button>)}
      </div>
      <p style={{color:C.muted,fontSize:14,marginBottom:20}}>{pool.length} questions available in "{cat}"</p>
      <button onClick={startQuiz} style={{padding:"12px 28px",background:C.gold,color:"#000",border:"none",borderRadius:8,fontSize:16,fontWeight:700,cursor:"pointer"}}>Start Quiz</button>
    </div>
  );

  if(finished) return (
    <div style={{maxWidth:900,margin:"0 auto",padding:"24px 16px",textAlign:"center"}}>
      <div style={{fontSize:64}}>{score.correct/score.total>=0.75?"🎉":"📚"}</div>
      <h2 style={{color:C.gold,fontFamily:"Georgia,serif",fontSize:28}}>{score.correct}/{score.total}</h2>
      <p style={{color:C.text,fontSize:18}}>{Math.round(score.correct/score.total*100)}% — {score.correct/score.total>=0.75?"Passing":"Keep Studying"}</p>
      <div style={{display:"flex",gap:12,justifyContent:"center",marginTop:24,flexWrap:"wrap"}}>
        <button onClick={startQuiz} style={{padding:"12px 24px",background:C.gold,color:"#000",border:"none",borderRadius:8,fontSize:14,fontWeight:700,cursor:"pointer"}}>Retake Quiz</button>
        <button onClick={()=>setShuffled(null)} style={{padding:"12px 24px",background:C.card,color:C.text,border:`1px solid ${C.border}`,borderRadius:8,fontSize:14,cursor:"pointer"}}>Change Topic</button>
      </div>
    </div>
  );

  const q=shuffled[idx];
  const ans=(selected)=>{
    if(selected!==null)return;
    const correct=ans===q.correct;
    setSelected(ans);setShowExp(true);
    setScore(s=>({correct:s.correct+(correct?1:0),total:s.total+1}));
  };
  const next=()=>{
    if(idx+1>=shuffled.length){setFinished(true);}
    else{setIdx(i=>i+1);setSelected(null);setShowExp(false);}
  };
  const handleAnswer=(i)=>{
    if(selected!==null)return;
    const correct=i===q.correct;
    setSelected(i);setShowExp(true);
    setScore(s=>({correct:s.correct+(correct?1:0),total:s.total+1}));
  };

  return (
    <div style={{maxWidth:700,margin:"0 auto",padding:"24px 16px"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <span style={{color:C.muted,fontSize:13}}>{cat} · Q{idx+1}/{shuffled.length}</span>
        <span style={{color:C.gold,fontSize:13,fontWeight:700}}>{score.correct}/{score.total} correct</span>
      </div>
      <div style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:12,padding:"24px",marginBottom:16}}>
        <div style={{color:C.muted,fontSize:11,marginBottom:8,textTransform:"uppercase",letterSpacing:1}}>{q.category}</div>
        <p style={{color:C.text,fontSize:17,lineHeight:1.6,margin:"0 0 20px",fontFamily:"Georgia,serif"}}>{q.question}</p>
        <div style={{display:"flex",flexDirection:"column",gap:8}}>
          {q.options.map((opt,i)=>{
            let bg=C.card,border=C.border,textColor=C.text;
            if(selected!==null){
              if(i===q.correct){bg="#1a2e1a";border=C.green;textColor=C.green;}
              else if(i===selected&&i!==q.correct){bg="#2e1a1a";border=C.red;textColor=C.red;}
            }
            return (
              <button key={i} onClick={()=>handleAnswer(i)} style={{background:bg,border:`1px solid ${border}`,color:textColor,padding:"12px 16px",borderRadius:8,textAlign:"left",cursor:selected!==null?"default":"pointer",fontSize:14,lineHeight:1.4,transition:"all .15s"}}>
                <span style={{color:C.muted,marginRight:8}}>{["A","B","C","D"][i]}.</span>{opt}
              </button>
            );
          })}
        </div>
      </div>
      {showExp&&(
        <div style={{background:"#111820",border:`1px solid ${C.blue}`,borderRadius:10,padding:"16px",marginBottom:16}}>
          <div style={{color:C.blue,fontSize:12,fontWeight:700,marginBottom:6,textTransform:"uppercase",letterSpacing:1}}>Explanation</div>
          <p style={{color:C.text,fontSize:14,margin:"0 0 10px",lineHeight:1.5}}>{q.explanation}</p>
          <div style={{color:C.goldDim,fontSize:12,fontWeight:700,marginBottom:4}}>EXAM STRATEGY</div>
          <p style={{color:C.muted,fontSize:13,margin:0,lineHeight:1.5}}>{q.strategy}</p>
        </div>
      )}
      {showExp&&(
        <button onClick={next} style={{width:"100%",padding:"12px",background:C.gold,color:"#000",border:"none",borderRadius:8,fontSize:15,fontWeight:700,cursor:"pointer"}}>
          {idx+1>=shuffled.length?"View Results →":"Next Question →"}
        </button>
      )}
    </div>
  );
}

// ── FLASHCARDS ────────────────────────────────────────────────
function Flashcards({flashcards}){
  const cats=["All",...new Set(flashcards.map(f=>f.category))];
  const [cat,setCat]=useState("All");
  const [idx,setIdx]=useState(0);
  const [flipped,setFlipped]=useState(false);
  const [gotIt,setGotIt]=useState([]);
  const [review,setReview]=useState([]);

  const pool=flashcards.filter(f=>cat==="All"||f.category===cat);
  const remaining=pool.filter(f=>![...gotIt,...review].includes(f.id));
  const card=remaining[idx%Math.max(remaining.length,1)];

  const handle=(type)=>{
    if(type==="got") setGotIt(g=>[...g,card.id]);
    else setReview(r=>[...r,card.id]);
    setFlipped(false);
    const nextRemaining=pool.filter(f=>![...gotIt,...review,card.id].includes(f.id));
    if(idx>=nextRemaining.length-1) setIdx(0);
  };

  const reset=()=>{setGotIt([]);setReview([]);setIdx(0);setFlipped(false);};

  if(pool.length===0) return <div style={{padding:24,color:C.muted}}>No flashcards for this filter.</div>;

  const done=remaining.length===0;

  return (
    <div style={{maxWidth:700,margin:"0 auto",padding:"24px 16px"}}>
      <h2 style={{color:C.gold,fontFamily:"Georgia,serif",marginBottom:12}}>Flashcards</h2>
      <div style={{display:"flex",flexWrap:"wrap",gap:6,marginBottom:16}}>
        {cats.map(c=> <button key={c} onClick={()=>{setCat(c);setIdx(0);setFlipped(false);setGotIt([]);setReview([]);}} style={btnStyle(cat===c,false)}>{c}</button>)}
      </div>
      <div style={{display:"flex",gap:12,fontSize:13,color:C.muted,marginBottom:16}}>
        <span>Remaining: <b style={{color:C.text}}>{remaining.length}</b></span>
        <span>Got It: <b style={{color:C.green}}>{gotIt.filter(id=>pool.find(f=>f.id===id)).length}</b></span>
        <span>Review: <b style={{color:C.red}}>{review.filter(id=>pool.find(f=>f.id===id)).length}</b></span>
      </div>
      {done?(
        <div style={{textAlign:"center",padding:"40px 0"}}>
          <div style={{fontSize:48}}>✅</div>
          <h3 style={{color:C.gold,fontFamily:"Georgia,serif"}}>Deck Complete!</h3>
          <p style={{color:C.muted,fontSize:14}}>Got It: {gotIt.filter(id=>pool.find(f=>f.id===id)).length} | Need Review: {review.filter(id=>pool.find(f=>f.id===id)).length}</p>
          <button onClick={reset} style={{padding:"12px 28px",background:C.gold,color:"#000",border:"none",borderRadius:8,fontSize:14,fontWeight:700,cursor:"pointer",marginTop:12}}>Reset Deck</button>
        </div>
      ):(
        <>
          <div onClick={()=>setFlipped(f=>!f)} style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:12,padding:"32px 24px",minHeight:180,cursor:"pointer",display:"flex",flexDirection:"column",justifyContent:"center",alignItems:"center",textAlign:"center",marginBottom:16,userSelect:"none"}}>
            <div style={{color:C.muted,fontSize:11,textTransform:"uppercase",letterSpacing:1,marginBottom:12}}>{flipped?"Answer":"Question"} · {card.category}</div>
            <p style={{color:flipped?C.gold:C.text,fontSize:flipped?15:17,lineHeight:1.6,margin:0,fontFamily:"Georgia,serif"}}>{flipped?card.back:card.front}</p>
            {!flipped&&<p style={{color:C.muted,fontSize:12,margin:"12px 0 0"}}>Tap to reveal</p>}
          </div>
          {flipped&&(
            <div style={{display:"flex",gap:12}}>
              <button onClick={()=>handle("review")} style={{flex:1,padding:"12px",background:"#2e1a1a",border:`1px solid ${C.red}`,color:C.red,borderRadius:8,fontSize:14,fontWeight:700,cursor:"pointer"}}>Review Again</button>
              <button onClick={()=>handle("got")} style={{flex:1,padding:"12px",background:"#1a2e1a",border:`1px solid ${C.green}`,color:C.green,borderRadius:8,fontSize:14,fontWeight:700,cursor:"pointer"}}>Got It ✓</button>
            </div>
          )}
        </>
      )}
    </div>
  );
}

