    if(code.trim().toUpperCase()===VALID_CODE){onUnlock();}
    else{setErr(true);setTimeout(()=>setErr(false),1200);}
  };
  return (
    <div style={{minHeight:"100vh",background:C.bg,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:"Georgia,serif"}}>
      <div style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:12,padding:"48px 40px",maxWidth:400,width:"90%",textAlign:"center"}}>
        <div style={{fontSize:40,marginBottom:16}}>🏛️</div>
