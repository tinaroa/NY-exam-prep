          style={{width:"100%",boxSizing:"border-box",padding:"12px 16px",borderRadius:8,border:`1px solid ${err?"#E57373":C.border}`,background:"#111",color:C.text,fontSize:16,fontFamily:"Georgia,serif",textAlign:"center",letterSpacing:2,outline:"none",marginBottom:12}}
        />
        <button onClick={submit} style={{width:"100%",padding:"12px",background:C.gold,color:"#000",border:"none",borderRadius:8,fontSize:16,fontWeight:700,cursor:"pointer",fontFamily:"Georgia,serif"}}>
