const FLASHCARDS=[
{id:1,category:"Law of Agency",front:"What does COLDAC stand for?",back:"Care, Obedience, Loyalty, Disclosure, Accounting, Confidentiality — the six fiduciary duties an agent owes their principal."},
{id:2,category:"Law of Agency",front:"What is special agency?",back:"Agency limited to one specific transaction. The most common type in real estate — a broker is hired to sell one property."},
{id:3,category:"Law of Agency",front:"When must NY agency disclosure be provided?",back:"At first substantive contact — before any agreements are signed. Both buyers and sellers must receive the form."},
{id:4,category:"Law of Agency",front:"What is designated agency?",back:"Two salespersons from the same firm represent opposite sides of a transaction, with the broker as a neutral party."},
{id:5,category:"Law of Agency",front:"What does dual agency require in NY?",back:"Informed written consent from both buyer and seller before the broker can represent both in the same transaction."},
{id:6,category:"Contracts",front:"What are the 4 essential elements of a valid contract?",back:"1) Offer and acceptance, 2) Consideration, 3) Legally competent parties, 4) Lawful object. All four must be present."},
{id:7,category:"Contracts",front:"Void vs. voidable contract — key difference?",back:"Void has no legal effect (illegal purpose). Voidable can be cancelled by the protected party only (e.g., a minor)."},
{id:8,category:"Contracts",front:"Exclusive right to sell vs. exclusive agency?",back:"Exclusive right to sell: broker earns commission no matter who sells. Exclusive agency: seller can sell themselves without paying commission."},
{id:9,category:"Contracts",front:"What is an option contract?",back:"Buyer has the RIGHT but not OBLIGATION to purchase at an agreed price within a set time. Seller is bound; buyer is not."},
{id:10,category:"Contracts",front:"What does the Statute of Frauds require for real estate?",back:"Real estate contracts must be in writing to be enforceable. Verbal real estate contracts are unenforceable."},
{id:11,category:"Property Ownership & Land Use",front:"What are the 4 unities of joint tenancy (TTIP)?",back:"Time (acquired at same time), Title (same deed), Interest (equal shares), Possession (equal right to use)."},
{id:12,category:"Property Ownership & Land Use",front:"What happens to a joint tenant's interest when they die?",back:"Passes automatically to surviving joint tenant(s) via right of survivorship — bypasses probate and overrides any will."},
{id:13,category:"Property Ownership & Land Use",front:"Co-op vs. condo — what does each buyer receive?",back:"Co-op: shares in a corporation + proprietary lease (no deed). Condo: fee simple deed + undivided interest in common areas."},
{id:14,category:"Property Ownership & Land Use",front:"What is an easement appurtenant?",back:"An easement benefiting an adjacent property (dominant estate). It runs with the land automatically."},
{id:15,category:"Property Ownership & Land Use",front:"What is eminent domain?",back:"Government power to take private property for public use, with payment of just compensation to the owner."},
{id:16,category:"Property Ownership & Land Use",front:"What creates an easement by prescription in NY?",back:"Open, continuous, hostile, actual use of another's land for 10 years. Creates a use right — not ownership."},
{id:17,category:"Finance & Mortgages",front:"What is LTV and the PMI threshold?",back:"LTV = Loan ÷ Appraised Value. PMI is required on conventional loans when LTV exceeds 80%."},
{id:18,category:"Finance & Mortgages",front:"What is one mortgage point?",back:"1% of the loan amount paid at closing to reduce the interest rate. On a $400,000 loan, one point = $4,000."},
{id:19,category:"Finance & Mortgages",front:"Income approach formula?",back:"Value = NOI ÷ Cap Rate (Net Operating Income divided by Capitalization Rate)."},
{id:20,category:"Finance & Mortgages",front:"What is a due-on-sale clause?",back:"Makes the entire loan balance due when the property is sold. Prevents assumption without lender approval."},
{id:21,category:"Finance & Mortgages",front:"FHA vs. VA minimum down payment?",back:"FHA: 3.5% down (qualifying credit scores). VA: 0% down for eligible veterans. Both government-backed."},
{id:22,category:"Valuation & Appraisal",front:"CBS / CIA in appraisal?",back:"CBS: Comparable Better → Subtract from the comp. CIA: Comparable Inferior → Add to the comp. Always adjust the comparable to match the subject."},
{id:23,category:"Valuation & Appraisal",front:"Three types of depreciation?",back:"1) Physical deterioration (wear/tear), 2) Functional obsolescence (outdated features), 3) External obsolescence (outside forces — always incurable)."},
{id:24,category:"Valuation & Appraisal",front:"What is plottage?",back:"Increase in value from combining adjacent parcels into one larger parcel. The whole is worth more than the sum of its parts."},
{id:25,category:"Valuation & Appraisal",front:"Best appraisal approach for a new school?",back:"Cost Approach — best for unique properties, new construction, or properties that don't generate income and rarely sell."},
{id:26,category:"Fair Housing",front:"7 federal Fair Housing protected classes?",back:"Race, Color, Religion, National Origin, Sex, Disability, Familial Status. Disability and Familial Status added in 1988."},
{id:27,category:"Fair Housing",front:"What is blockbusting?",back:"Inducing homeowners to sell by suggesting a protected class is moving into the area and lowering property values. Federally illegal."},
{id:28,category:"Fair Housing",front:"What is steering?",back:"Directing buyers or renters toward or away from certain neighborhoods based on their membership in a protected class."},
{id:29,category:"Fair Housing",front:"What NY-specific class relates to housing subsidies?",back:"Source of lawful income — landlords cannot refuse Section 8 vouchers or other legal income sources as a basis for rejection."},
{id:30,category:"Fair Housing",front:"What is the Mrs. Murphy exemption?",back:"Owner-occupied buildings with 4 or fewer units are exempt from federal Fair Housing — if sold without a broker and without discriminatory advertising."},
{id:31,category:"Deeds & Title",front:"Which deed offers the strongest buyer protection?",back:"General Warranty Deed — grantor warrants against all title defects, even those from before they owned the property."},
{id:32,category:"Deeds & Title",front:"What is a quitclaim deed?",back:"Conveys only whatever interest the grantor has — no warranties. May convey nothing. Used for family transfers, divorce, clearing title."},
{id:33,category:"Deeds & Title",front:"Actual notice vs. constructive notice?",back:"Actual: personally informed. Constructive: document is in public record — you're legally presumed to know it even if you didn't check."},
{id:34,category:"Deeds & Title",front:"When is a Bargain and Sale deed used in NY?",back:"Common in NY foreclosure and tax sales, where the grantor cannot guarantee a clear chain of title."},
{id:35,category:"Broker License Law",front:"NY broker licensing requirements?",back:"Age 20+, 2 years licensed salesperson experience, 120 hours qualifying education, pass exam, apply within 2 years of passing."},
{id:36,category:"Broker License Law",front:"Commingling vs. conversion?",back:"Commingling: mixing client funds with broker's funds (illegal). Conversion: using client funds for personal use (criminal)."},
{id:37,category:"Broker License Law",front:"CE hours for NY license renewal?",back:"22.5 hours of continuing education every 2 years — required for both salespersons and brokers."},
{id:38,category:"Broker License Law",front:"When is a broker's commission earned?",back:"When a ready, willing, and able buyer is produced — even if the transaction doesn't close, unless the contract says otherwise."},
{id:39,category:"Real Estate Math",front:"$680,000 sale, 6% commission, 50/50 split. Salesperson gets 65% of broker's share. What does she earn?",back:"$680,000 × 6% = $40,800 → $20,400 per broker → $20,400 × 65% = $13,260"},
{id:40,category:"Real Estate Math",front:"Annual taxes $5,400 using 360-day year. Daily proration rate?",back:"$5,400 ÷ 360 = $15 per day"},
{id:41,category:"Real Estate Math",front:"NOI $72,000, cap rate 8%. Property value?",back:"$72,000 ÷ 0.08 = $900,000"},
{id:42,category:"Real Estate Math",front:"$360,000 mortgage on $400,000 home. LTV?",back:"$360,000 ÷ $400,000 = 90% LTV (PMI required)"},
{id:43,category:"Real Estate Math",front:"Home appreciated 12%, now worth $448,000. Original price?",back:"$448,000 ÷ 1.12 = $400,000"},
{id:44,category:"Real Estate Math",front:"Lot is 220 ft × 396 ft. How many acres?",back:"220 × 396 = 87,120 sq ft ÷ 43,560 = 2 acres"},
{id:45,category:"Test Strategy & Tricky Questions",front:"What does 'EXCEPT' in a question mean?",back:"Find the one answer that does NOT fit the pattern of the other three. The odd one out is your answer."},
{id:46,category:"Test Strategy & Tricky Questions",front:"'Always' and 'never' in answer choices usually signal:",back:"Wrong answers. Real estate law has many exceptions. 'Generally,' 'typically,' and 'may' are safer qualifiers."},
{id:47,category:"Test Strategy & Tricky Questions",front:"What is a ready, willing, and able buyer?",back:"Ready (able to buy now), Willing (wants this property on these terms), Able (financially qualified to close). All three required."},
{id:48,category:"Test Strategy & Tricky Questions",front:"NY broker exam: questions and time limit?",back:"100 questions, 2.5 hours (150 minutes) = 1.5 minutes per question. No penalty for guessing."},
{id:49,category:"Test Strategy & Tricky Questions",front:"NY salesperson exam: questions and time limit?",back:"75 questions, 90 minutes = 1.2 minutes per question. No penalty for guessing."},
{id:50,category:"Test Strategy & Tricky Questions",front:"When two answers seem equally right, how do you choose?",back:"Pick the one that is more consumer-protective, more legally precise, or reflects the fiduciary duty to the client. NY exam writers favor consumer protection."},
];

const QUESTIONS=[
// LAW OF AGENCY (20)
{id:1,category:"Law of Agency",exam:"both",question:"A salesperson working for a listing broker represents which party?",options:["The buyer","The seller, through the broker","Both parties equally","Neither until disclosed"],correct:1,explanation:"Salespersons extend their broker's agency. When the broker represents the seller, so does the salesperson.",strategy:"Trace upward: Salesperson → Broker → Principal."},
{id:2,category:"Law of Agency",exam:"both",question:"Which fiduciary duty requires following all lawful instructions of the principal?",options:["Loyalty","Care","Obedience","Disclosure"],correct:2,explanation:"Obedience requires following lawful instructions even if the agent disagrees. Illegal instructions must be refused.",strategy:"COLDAC: O = Obedience. Loyalty = putting client first, which is different."},
{id:3,category:"Law of Agency",exam:"both",question:"Dual agency in NY requires:",options:["Verbal consent from both parties","Written informed consent from both parties","DOS approval","A separate transaction broker agreement"],correct:1,explanation:"NY requires informed written consent from both buyer and seller before dual agency can occur.",strategy:"Dual agency + NY = always written. Verbal is never enough."},
{id:4,category:"Law of Agency",exam:"both",question:"When must a NY licensee provide the agency disclosure form?",options:["At the time of the offer","Before showing property","At first substantive contact","When buyer is pre-approved"],correct:2,explanation:"NY law requires the disclosure form at first substantive contact — before any agreements are signed.",strategy:"First substantive contact = the trigger. Not at closing, not at offer."},
{id:5,category:"Law of Agency",exam:"both",question:"A seller's agent learns the seller will accept $50,000 less than list price. The agent must:",options:["Share it with the buyer to facilitate the sale","Keep it confidential — protected by duty of confidentiality","Disclose to buyer's agent only","Report it to DOS"],correct:1,explanation:"The duty of confidentiality requires protecting the seller's negotiating position.",strategy:"Agency question: who does the duty run to? Seller's agent protects the seller — always."},
{id:6,category:"Law of Agency",exam:"both",question:"Which type of agency is most common in a single real estate transaction?",options:["Universal agency","General agency","Special agency","Ostensible agency"],correct:2,explanation:"Special agency is limited to one specific transaction — the broker hired to sell one property.",strategy:"Universal (all matters) → General (ongoing) → Special (one transaction). RE = Special."},
{id:7,category:"Law of Agency",exam:"both",question:"In designated agency, the broker's role is to:",options:["Represent both parties personally","Act as neutral while two salespersons represent opposite sides","Withdraw from the transaction","Represent whoever made first contact"],correct:1,explanation:"Designated agency allows two salespersons in the same firm to each represent one side, with the broker neutral.",strategy:"Designated ≠ dual. Each client still has their own dedicated salesperson."},
{id:8,category:"Law of Agency",exam:"both",question:"A buyer's agent is paid by the seller per MLS agreement. The fiduciary duty runs to:",options:["The seller, since they pay","The buyer, regardless of who pays","Both equally","The MLS"],correct:1,explanation:"Agency is determined by the representation agreement, not who pays the commission.",strategy:"Who pays ≠ who is represented. Compensation never determines agency."},
{id:9,category:"Law of Agency",exam:"both",question:"Which duty requires the agent to use reasonable skill and expertise?",options:["Loyalty","Obedience","Care","Accounting"],correct:2,explanation:"The duty of Care requires performing with the skill, care, and diligence of a competent professional.",strategy:"Care = competence. If you see 'skill' or 'expertise' in the answer, that's Care."},
{id:10,category:"Law of Agency",exam:"both",question:"Agency is terminated by all of the following EXCEPT:",options:["Mutual agreement","Expiration of the listing period","Death of the salesperson (not the broker)","Destruction of the property"],correct:2,explanation:"Death of the salesperson alone does not terminate agency — the broker's license governs the relationship. Death of the broker or principal does terminate it.",strategy:"Agency runs through the BROKER, not the salesperson. Salesperson death alone doesn't end it."},
{id:11,category:"Law of Agency",exam:"both",question:"A buyer's agent discovers a material defect in the property. The agent must:",options:["Keep it confidential to protect the buyer's negotiating position","Disclose it to the buyer","Disclose it to the seller's agent","Only disclose if the buyer asks"],correct:1,explanation:"The duty of disclosure requires an agent to reveal all material facts to their client.",strategy:"Disclosure duty = reveal material facts to YOUR client. Buyer's agent → tell the buyer."},
{id:12,category:"Law of Agency",exam:"both",question:"What is the primary difference between a client and a customer in real estate?",options:["A client pays more commission","A client has a signed representation agreement and receives fiduciary duties; a customer does not","A customer can sue the agent; a client cannot","There is no legal distinction"],correct:1,explanation:"A client has a formal agency relationship and receives all fiduciary duties. A customer receives honest, fair dealing only.",strategy:"Client = fiduciary (COLDAC). Customer = honest dealing only. The difference is the signed agreement."},
{id:13,category:"Law of Agency",exam:"both",question:"A listing agent learns the seller's property has a hidden structural defect. The agent must:",options:["Keep it confidential per the duty of loyalty","Disclose it to prospective buyers","Only disclose if asked directly","Disclose only after the contract is signed"],correct:1,explanation:"Material defects must be disclosed to prospective buyers regardless of the agency relationship. This overrides confidentiality.",strategy:"Material defects are ALWAYS disclosed. Confidentiality never protects hiding defects from buyers."},
{id:14,category:"Law of Agency",exam:"both",question:"Ostensible (apparent) agency occurs when:",options:["A principal expressly authorizes an agent","A third party reasonably believes someone is an agent based on the principal's conduct","An agent acts beyond their authority","Two agents represent the same party"],correct:1,explanation:"Ostensible agency arises when a principal's words or actions lead a third party to reasonably believe an agency relationship exists, even without formal authorization.",strategy:"Ostensible = apparent. The principal's conduct creates the impression of agency."},
{id:15,category:"Law of Agency",exam:"both",question:"Which best describes the duty of accounting?",options:["Filing tax returns for the client","Keeping accurate records and promptly handling all client funds and documents","Reporting all transactions to the DOS","Providing a monthly financial statement to the principal"],correct:1,explanation:"Accounting requires the agent to properly handle all client funds, maintain records, and promptly deliver money and documents.",strategy:"Accounting = money handling. Escrow deposits, receipts, documents — all must be tracked and delivered promptly."},
{id:16,category:"Law of Agency",exam:"both",question:"A seller instructs the listing agent not to show the home to buyers of a specific national origin. The agent should:",options:["Follow the instruction — the seller is the principal","Refuse and explain it violates Fair Housing law","Follow it but document in writing","Disclose the restriction to the MLS"],correct:1,explanation:"Agents must refuse illegal instructions. Fair Housing prohibits discrimination based on national origin.",strategy:"Obedience only applies to LAWFUL instructions. Illegal orders must always be refused."},
{id:17,category:"Law of Agency",exam:"both",question:"A broker represents the seller. The buyer has no agent. The broker's duty to the buyer is:",options:["Full fiduciary duty","Honest and fair dealing only","Keep seller's info confidential while sharing buyer's info freely","No duty at all"],correct:1,explanation:"An unrepresented buyer (customer) is owed honest and fair dealing — not fiduciary duties.",strategy:"Unrepresented buyer = customer = honest dealing. Fiduciary duties only to the client."},
{id:18,category:"Law of Agency",exam:"both",question:"Which statement about subagency is correct?",options:["Subagents represent the buyer","Subagents represent the seller through the listing broker","Subagency is required in all MLS transactions","Subagents owe no duty to any party"],correct:1,explanation:"A subagent works with buyers but represents the seller through the listing broker. Subagency is rarely used today.",strategy:"Subagent = works with buyer but represents seller. This is why buyer agency agreements became important."},
{id:19,category:"Law of Agency",exam:"both",question:"The fiduciary duty of loyalty requires the agent to:",options:["Be loyal to both buyer and seller simultaneously","Place the client's interests above all others, including the agent's own interests","Remain loyal to the agency regardless of client instructions","Never disclose anything to any third party"],correct:1,explanation:"Loyalty means the agent puts the client's interests first — above the agent's own financial interest and any third party.",strategy:"Loyalty = client first, always. Agent profiting at client's expense = breach of loyalty."},
{id:20,category:"Law of Agency",exam:"both",question:"An agent who exceeds their authority and enters a contract on behalf of the principal creates:",options:["Implied agency","Ratified agency","Unauthorized agency","Ostensible agency"],correct:2,explanation:"When an agent acts beyond their granted authority, they act without authorization. The principal may ratify or reject the act.",strategy:"Exceeds authority = unauthorized. If the principal later approves it, it becomes ratified."},
// CONTRACTS (20)
{id:21,category:"Contracts",exam:"both",question:"A buyer signs a purchase contract but is 17 years old. The contract is:",options:["Void","Voidable by the buyer","Voidable by the seller","Valid if parents co-sign after"],correct:1,explanation:"A contract with a minor is voidable — but only by the minor. The seller cannot use the buyer's age to escape.",strategy:"Voidable protects the weaker party — only THAT party can void it."},
{id:22,category:"Contracts",exam:"both",question:"Under an exclusive right to sell listing, the broker earns commission when:",options:["Only if broker finds the buyer","When any cooperating broker finds the buyer","When the property sells to any buyer regardless of who found them","Only if seller accepts list price"],correct:2,explanation:"Exclusive right to sell means the broker earns commission regardless of who produces the buyer — including the seller.",strategy:"Exclusive RIGHT to sell = broker earns no matter what. Exclusive AGENCY = seller can sell themselves."},
{id:23,category:"Contracts",exam:"both",question:"Which is NOT an essential element of a valid contract?",options:["Consideration","Lawful object","Written form","Legally competent parties"],correct:2,explanation:"The four essential elements are offer/acceptance, consideration, competent parties, and lawful object. Writing is required for enforceability, not validity.",strategy:"Valid ≠ Enforceable. A verbal RE contract can be valid but unenforceable."},
{id:24,category:"Contracts",exam:"both",question:"An option contract legally binds which party?",options:["The buyer only","The seller only","Both equally","Neither until exercised"],correct:1,explanation:"The seller (optionor) is bound — cannot sell to anyone else during the option period. The buyer has the right but not obligation to buy.",strategy:"Option = one-way. SELLER locked in; BUYER has flexibility."},
{id:25,category:"Contracts",exam:"both",question:"A verbal real estate purchase contract is best described as:",options:["Valid and enforceable","Void","Voidable","Unenforceable"],correct:3,explanation:"The Statute of Frauds requires RE contracts in writing. A verbal RE contract is unenforceable — not void.",strategy:"Unenforceable ≠ Void. Courts won't enforce it, but the underlying agreement isn't illegal."},
{id:26,category:"Contracts",exam:"both",question:"A seller accepts an offer, then finds a better offer and wants to back out. The seller:",options:["Can withdraw if no money changed hands","Is bound once acceptance was communicated","Has 3 days to rescind under federal law","Can withdraw if buyer hasn't signed yet"],correct:1,explanation:"A binding contract forms when acceptance is communicated to the offeror. After that, the seller cannot unilaterally withdraw.",strategy:"Meeting of the minds = offer + acceptance communicated. No automatic 3-day rescission in purchase contracts."},
{id:27,category:"Contracts",exam:"both",question:"A right of first refusal means:",options:["The buyer can refuse the seller's counteroffer","A party must be offered the property before it can be sold to others","The seller can refuse any offer under a set price","The broker can refuse an unqualified buyer"],correct:1,explanation:"Right of first refusal gives a party the right to match any offer before the owner can sell to someone else.",strategy:"First refusal = right to match before it goes elsewhere."},
{id:28,category:"Contracts",exam:"both",question:"A counteroffer legally:",options:["Accepts the original offer with minor changes","Rejects the original offer and creates a new offer","Extends the original offer's expiration","Binds both parties immediately"],correct:1,explanation:"A counteroffer simultaneously rejects the original offer and proposes new terms.",strategy:"Counteroffer = rejection + new offer. The original offer is dead once a counter is made."},
{id:29,category:"Contracts",exam:"both",question:"Earnest money held in escrow belongs to:",options:["The broker","The seller","The buyer, until title transfers or contract specifies otherwise","The listing agent"],correct:2,explanation:"Earnest money is the buyer's funds held in trust. It's not the broker's money.",strategy:"Escrow = held in trust, not owned by broker. Belongs to buyer until contractually transferred."},
{id:30,category:"Contracts",exam:"both",question:"Which listing agreement type gives the owner the right to sell themselves without paying a commission?",options:["Exclusive right to sell","Exclusive agency","Open listing","Net listing"],correct:1,explanation:"Under exclusive agency, the broker has the exclusive right to represent the seller, but if the seller finds their own buyer, no commission is owed.",strategy:"Exclusive agency ≠ exclusive right to sell. Agency = seller can self-sell. Right to sell = broker always paid."},
{id:31,category:"Contracts",exam:"both",question:"A net listing is one where:",options:["The broker earns a flat fee","The broker earns everything above the seller's net price","Both parties split proceeds equally","The broker charges a percentage of net profit"],correct:1,explanation:"A net listing pays the broker all proceeds above the seller's desired net amount. Illegal in many states due to conflict of interest.",strategy:"Net listings create a conflict — broker benefits by lowering the price. Illegal or discouraged in most states."},
{id:32,category:"Contracts",exam:"both",question:"The doctrine of specific performance allows:",options:["A buyer to sue for damages only","A court to force a party to complete a real estate contract","A broker to keep the commission if the deal falls through","An agent to represent both parties without consent"],correct:1,explanation:"Specific performance forces a party to fulfill the exact terms of a contract — unique for real estate since each property is considered unique.",strategy:"Specific performance = force completion. Available in RE because land is unique."},
{id:33,category:"Contracts",exam:"both",question:"A bilateral contract is one in which:",options:["Only one party makes a promise","Both parties exchange promises","A third party guarantees performance","The contract is recorded in public records"],correct:1,explanation:"A bilateral contract involves mutual promises — both parties are bound. Most real estate purchase contracts are bilateral.",strategy:"Bilateral = two-sided promises. Unilateral = one party promises, other acts (like option contracts)."},
{id:34,category:"Contracts",exam:"both",question:"Which of the following would make a contract void?",options:["One party is 17 years old","The contract was not witnessed","The contract has an illegal purpose","The contract was not recorded"],correct:2,explanation:"An illegal purpose (unlawful object) makes a contract void — it has no legal effect from the start.",strategy:"Void = illegal purpose or no legal effect at all. Voidable = one party has the right to cancel."},
{id:35,category:"Contracts",exam:"both",question:"Novation in a real estate contract means:",options:["Adding a new party with the original contract intact","Replacing an old contract with a new one, releasing the original party","Assigning rights to a third party","Extending the closing date"],correct:1,explanation:"Novation substitutes a new contract or party for the old one, completely releasing the original party from liability.",strategy:"Novation = new contract, old one dies. Assignment transfers rights but keeps original party liable."},
{id:36,category:"Contracts",exam:"both",question:"A purchase contract contingency protects:",options:["Only the seller","Only the buyer","The party for whose benefit it was written","Both parties equally in all cases"],correct:2,explanation:"Contingencies benefit the party for whom they were written — usually the buyer. That party can waive it.",strategy:"Contingencies = protection for the party they were written for."},
{id:37,category:"Contracts",exam:"both",question:"When a buyer defaults on a purchase contract, a liquidated damages clause typically means:",options:["The buyer owes all lost profits","The seller keeps the earnest money as full compensation","The buyer must complete the purchase","The seller can sue for additional damages"],correct:1,explanation:"A liquidated damages clause pre-sets the damages — usually the earnest money — as the seller's sole remedy if the buyer defaults.",strategy:"Liquidated damages = pre-agreed remedy. Seller keeps deposit; can't usually sue for more."},
{id:38,category:"Contracts",exam:"both",question:"An agreement to agree is:",options:["A binding preliminary contract","Generally not enforceable because material terms are missing","Enforceable if signed by both parties","The same as a letter of intent"],correct:1,explanation:"An agreement to agree lacks definitive terms and is generally unenforceable. Courts cannot enforce a contract when essential terms are still to be negotiated.",strategy:"Missing material terms = no binding contract. 'We'll work it out later' is not a contract."},
{id:39,category:"Contracts",exam:"both",question:"Which clause allows the seller to accept a better offer while the first contract is pending?",options:["Contingency clause","Kick-out clause","Acceleration clause","Subordination clause"],correct:1,explanation:"A kick-out (bump) clause allows the seller to accept a better offer as long as they give the first buyer notice to remove contingencies or step aside.",strategy:"Kick-out clause = seller keeps marketing. First buyer gets notice to perform or walk."},
{id:40,category:"Contracts",exam:"both",question:"Which of the following is a unilateral contract?",options:["A purchase and sale agreement","An exclusive right to sell listing","An option contract","A buyer representation agreement"],correct:2,explanation:"An option contract is unilateral — the seller (optionor) is bound; the buyer (optionee) has a right but no obligation.",strategy:"Unilateral = one party bound. Bilateral = both parties bound. Option = unilateral."},
// FAIR HOUSING (20)
{id:41,category:"Fair Housing",exam:"both",question:"A landlord refuses to rent to a family because they have three children. This violates which class?",options:["Race","Disability","Familial status","National origin"],correct:2,explanation:"Familial status protects families with children under 18. Added to the FHA in the 1988 amendments.",strategy:"Families with children = familial status. 1988 added Disability AND Familial Status."},
{id:42,category:"Fair Housing",exam:"both",question:"An agent shows minority buyers homes only in certain neighborhoods while showing white buyers a wider range. This is:",options:["Blockbusting","Redlining","Steering","Filtering"],correct:2,explanation:"Steering is directing buyers toward or away from certain areas based on a protected class.",strategy:"Steering = directing WHERE. Blockbusting = panicking sellers. Redlining = banks refusing to lend."},
{id:43,category:"Fair Housing",exam:"both",question:"Under federal Fair Housing Act, which property is generally exempt?",options:["A 20-unit apartment complex","An owner-occupied duplex sold through a broker","An owner-occupied 3-unit building rented without a broker","A single-family home listed on MLS"],correct:2,explanation:"Mrs. Murphy exemption: owner-occupied, 4 units or fewer, sold/rented WITHOUT a broker, and no discriminatory advertising.",strategy:"All four conditions must be met: owner-occupied, ≤4 units, no broker, no discriminatory ads."},
{id:44,category:"Fair Housing",exam:"both",question:"An agent tells a homeowner 'values are declining because of who's moving in' to get a quick listing. This is:",options:["Legal if values are actually declining","Blockbusting — illegal","Protected speech","Steering"],correct:1,explanation:"Blockbusting is illegal regardless of whether values are actually changing.",strategy:"Blockbusting is illegal even if the statement is true. The act itself is the violation."},
{id:45,category:"Fair Housing",exam:"both",question:"A disabled tenant asks to install grab bars in the bathroom. The landlord must:",options:["Refuse — it alters the unit","Allow it at landlord's expense","Allow it at tenant's expense, with agreement to restore on vacating","Offer an alternative accessible unit"],correct:2,explanation:"Landlords must allow reasonable modifications for disabled tenants. The tenant pays and must agree to restore upon move-out.",strategy:"Modification (physical): tenant pays, tenant restores. Accommodation (policy): no cost, no restoration."},
{id:46,category:"Fair Housing",exam:"both",question:"Which is protected under NY State Human Rights Law but NOT federal Fair Housing?",options:["Disability","Sex","Marital status","Familial status"],correct:2,explanation:"NY State adds marital status, age, sexual orientation, gender identity, military status, and source of lawful income.",strategy:"Federal = 7 classes. NY adds more. Marital status and source of income are most tested NY additions."},
{id:47,category:"Fair Housing",exam:"both",question:"Redlining refers to:",options:["Steering buyers to certain neighborhoods","Refusing to make loans or insurance available in certain areas based on racial composition","Marking up values in minority neighborhoods","Refusing to list properties in certain zip codes"],correct:1,explanation:"Redlining is the illegal practice of lenders or insurers refusing to provide services in certain areas based on racial or ethnic composition.",strategy:"Redlining = financial institutions refusing to serve areas. Banks and insurers, not agents."},
{id:48,category:"Fair Housing",exam:"both",question:"Which federal agency primarily enforces the Fair Housing Act?",options:["FTC","HUD","DOS","FHA"],correct:1,explanation:"The Department of Housing and Urban Development (HUD) is the primary federal agency for Fair Housing enforcement.",strategy:"HUD = Fair Housing enforcement. FHA = Federal Housing Administration (loans). Don't confuse them."},
{id:49,category:"Fair Housing",exam:"both",question:"A real estate ad that says 'ideal for young professionals' could be considered discriminatory based on:",options:["Familial status and age","Race and national origin","Sex and disability","Religion and color"],correct:0,explanation:"'Young professionals' implies preference for younger people (age) and may exclude families with children (familial status).",strategy:"Advertising language is scrutinized carefully. Anything implying preference based on a protected class is problematic."},
{id:50,category:"Fair Housing",exam:"both",question:"A landlord requires all applicants to speak English as a condition of tenancy. This may violate:",options:["Religion","Sex","National origin","Familial status"],correct:2,explanation:"A blanket English-only requirement can be a proxy for national origin discrimination, a federally protected class.",strategy:"Language requirements can mask national origin discrimination. Courts scrutinize these policies."},
{id:51,category:"Fair Housing",exam:"both",question:"Under the Fair Housing Act, a 'reasonable accommodation' for a disabled person means:",options:["A physical modification to the unit","A change in rules, policies, or services to give a disabled person equal opportunity to use housing","Moving the disabled person to a ground-floor unit","Waiving all application fees"],correct:1,explanation:"A reasonable accommodation is a change in rules or policies — not a physical modification.",strategy:"Accommodation = policy change (no cost to tenant). Modification = physical change (tenant pays, tenant restores)."},
{id:52,category:"Fair Housing",exam:"both",question:"The Fair Housing Act was originally passed in:",options:["1954","1964","1968","1988"],correct:2,explanation:"The Fair Housing Act was enacted in 1968. The 1988 amendments added disability and familial status.",strategy:"1968 = original FHA. 1988 = added disability and familial status."},
{id:53,category:"Fair Housing",exam:"both",question:"An agent refuses to show a client homes in a neighborhood because 'that area isn't right for you.' This is most likely:",options:["Good advice","Steering","Blockbusting","Redlining"],correct:1,explanation:"Directing a client away from certain areas based on their protected class characteristics is steering, even when framed as advice.",strategy:"Steering can be subtle — 'you wouldn't like it there' based on demographics = steering."},
{id:54,category:"Fair Housing",exam:"both",question:"Which is NOT a protected class under the federal Fair Housing Act?",options:["Familial status","Disability","Sexual orientation","National origin"],correct:2,explanation:"Sexual orientation is NOT a federal Fair Housing protected class — though NY State law does protect it.",strategy:"Sexual orientation = NY protected, NOT federal. Know the difference."},
{id:55,category:"Fair Housing",exam:"both",question:"An owner of a single-family home who uses a broker to sell the property:",options:["Is exempt from the Fair Housing Act","Loses the Mrs. Murphy exemption","Is only subject to state law","Has limited liability under federal law"],correct:1,explanation:"Using a broker eliminates the Mrs. Murphy exemption. Once a broker is involved, all Fair Housing rules apply.",strategy:"Broker involved = no exemption, period. Mrs. Murphy exemption REQUIRES no broker."},
{id:56,category:"Fair Housing",exam:"both",question:"A property manager sets different security deposit amounts for tenants with disabilities. This is:",options:["Acceptable to offset higher risk","A violation of the Fair Housing Act","Required under NY law","Acceptable with written disclosure"],correct:1,explanation:"Charging different deposit amounts based on a protected class is discriminatory.",strategy:"Different terms or conditions based on protected class = discrimination. Applies to deposits, rent, rules — everything."},
{id:57,category:"Fair Housing",exam:"both",question:"Under NYC law, a landlord may NOT refuse to rent based on:",options:["Poor credit history","Prior evictions","Source of lawful income","Criminal background"],correct:2,explanation:"NYC and NY State prohibit discrimination based on source of lawful income — landlords cannot refuse Section 8 vouchers.",strategy:"Source of lawful income is a NY/NYC addition not found in federal law."},
{id:58,category:"Fair Housing",exam:"both",question:"The 'effects test' in Fair Housing means:",options:["Only intentional discrimination is illegal","A policy can be discriminatory even if not intentionally so, if it has a disparate impact on a protected class","Only written policies can be discriminatory","The effects of discrimination must be proven financially"],correct:1,explanation:"Disparate impact means a facially neutral policy can be illegal if it disproportionately harms a protected class.",strategy:"Effects test = disparate impact. Intent doesn't matter if the policy disproportionately affects a protected class."},
{id:59,category:"Fair Housing",exam:"both",question:"A religious organization that owns and operates housing exclusively for its members:",options:["Has no Fair Housing exemptions","May restrict occupancy to members of that religion in some circumstances","Must comply with all federal Fair Housing rules without exception","May discriminate based on any protected class"],correct:1,explanation:"Religious organizations may restrict occupancy to members of their religion in housing they own and operate — a narrow exemption.",strategy:"Religious org exemption is narrow: only for religion-based restriction, only in noncommercial housing they own."},
{id:60,category:"Fair Housing",exam:"both",question:"Which best describes the NY Human Rights Law complaint timeline?",options:["6 months","1 year","2 years","3 years"],correct:1,explanation:"In NY, complaints under the Human Rights Law must generally be filed within 1 year of the discriminatory act.",strategy:"NY Human Rights Law = 1 year to file. Federal HUD complaints = also 1 year."},
// FINANCE & MORTGAGES (20)
{id:61,category:"Finance & Mortgages",exam:"both",question:"A borrower takes a $300,000 loan on a $375,000 property. What is the LTV?",options:["75%","80%","85%","125%"],correct:1,explanation:"$300,000 ÷ $375,000 = 80% LTV. At exactly 80%, no PMI is required on a conventional loan.",strategy:"LTV = Loan ÷ Value. PMI kicks in above 80%."},
{id:62,category:"Finance & Mortgages",exam:"both",question:"One mortgage point equals:",options:["1% of the appraised value","1% of the loan amount","$1,000 flat","1 year of prepaid interest"],correct:1,explanation:"One point = 1% of the loan amount, paid at closing to reduce the mortgage rate.",strategy:"Points = always on the LOAN amount, not the purchase price."},
{id:63,category:"Finance & Mortgages",exam:"both",question:"New York uses which mortgage theory?",options:["Title theory","Lien theory","Intermediate theory","Trust deed theory"],correct:1,explanation:"NY is a lien theory state — borrower keeps title; lender holds a lien as security.",strategy:"NY = lien theory (borrower keeps title). Title theory = lender holds title until paid."},
{id:64,category:"Finance & Mortgages",exam:"both",question:"Minimum down payment for an FHA loan (qualifying credit)?",options:["0%","3.5%","5%","10%"],correct:1,explanation:"FHA loans require 3.5% minimum down for borrowers with a credit score of 580 or higher.",strategy:"FHA = 3.5%. VA = 0%. USDA = 0% (rural). Conventional = typically 5–20%."},
{id:65,category:"Finance & Mortgages",exam:"both",question:"Which mortgage clause prevents a buyer from assuming the seller's loan without lender approval?",options:["Defeasance clause","Subordination clause","Due-on-sale clause","Acceleration clause"],correct:2,explanation:"The due-on-sale clause makes the full balance due upon sale, preventing unauthorized loan assumptions.",strategy:"Due-on-sale = balance due upon sale. Acceleration = balance due upon default."},
{id:66,category:"Finance & Mortgages",exam:"both",question:"PMI is required on conventional loans when LTV exceeds:",options:["75%","80%","85%","90%"],correct:1,explanation:"PMI is required on conventional loans when the LTV exceeds 80% — meaning the borrower's down payment is less than 20%.",strategy:"80% LTV = 20% down = no PMI. Above 80% = PMI required."},
{id:67,category:"Finance & Mortgages",exam:"both",question:"An adjustable-rate mortgage (ARM) differs from a fixed-rate mortgage in that:",options:["The loan amount can change","The interest rate can change periodically based on an index","The term is always shorter","The lender can call the loan at any time"],correct:1,explanation:"An ARM has an interest rate that adjusts periodically based on a specified index plus a margin.",strategy:"ARM = rate can change. Fixed = rate stays constant. Index + margin = new ARM rate."},
{id:68,category:"Finance & Mortgages",exam:"both",question:"Which federal law requires lenders to disclose the APR and loan terms to borrowers?",options:["RESPA","TILA (Truth in Lending Act)","CRA","ECOA"],correct:1,explanation:"TILA requires lenders to disclose the APR, finance charges, and other loan terms to borrowers.",strategy:"TILA = Truth in Lending = APR disclosure. RESPA = settlement costs disclosure. Two different laws."},
{id:69,category:"Finance & Mortgages",exam:"both",question:"RESPA primarily governs:",options:["Fair Housing compliance","Appraisal standards","Disclosure of settlement costs and prohibits kickbacks","Mortgage interest rate caps"],correct:2,explanation:"RESPA requires disclosure of settlement costs and prohibits kickbacks between settlement service providers.",strategy:"RESPA = settlement cost disclosures + anti-kickback. No referral fees for business referrals."},
{id:70,category:"Finance & Mortgages",exam:"both",question:"The Equal Credit Opportunity Act (ECOA) prohibits lenders from discriminating based on:",options:["Credit score","Down payment amount","Race, color, religion, national origin, sex, marital status, or age","Employment history"],correct:2,explanation:"ECOA prohibits credit discrimination based on race, color, religion, national origin, sex, marital status, age, or receipt of public assistance.",strategy:"ECOA = credit discrimination. Similar protected classes as Fair Housing but applies to lending."},
{id:71,category:"Finance & Mortgages",exam:"both",question:"A balloon mortgage requires:",options:["Monthly payments that increase over time","A large lump-sum payment at the end of a shorter term","Equal monthly payments throughout the term","No payments until the property is sold"],correct:1,explanation:"A balloon mortgage has a large final payment due at the end of a relatively short term.",strategy:"Balloon = big payment at end. Not fully amortized — borrower must pay off or refinance at maturity."},
{id:72,category:"Finance & Mortgages",exam:"both",question:"Mortgage amortization means:",options:["The lender's profit on the loan","Gradual repayment of principal and interest over the loan term","The total interest paid over the life of the loan","The process of transferring the mortgage to a new borrower"],correct:1,explanation:"Amortization is the scheduled repayment of the loan through regular payments of principal and interest.",strategy:"Amortization = gradual payoff. Early = mostly interest. Late = mostly principal."},
{id:73,category:"Finance & Mortgages",exam:"both",question:"A home equity line of credit (HELOC) is best described as:",options:["A fixed-rate second mortgage","A revolving line of credit secured by the borrower's home equity","A government loan for home improvements","A loan that replaces the first mortgage"],correct:1,explanation:"A HELOC is a revolving credit line secured by the equity in a home. The borrower can draw, repay, and redraw up to the credit limit.",strategy:"HELOC = revolving (like a credit card) secured by home equity. Home equity loan = fixed lump sum."},
{id:74,category:"Finance & Mortgages",exam:"both",question:"The Community Reinvestment Act (CRA) requires:",options:["All banks to offer FHA loans","Depository institutions to meet the credit needs of all communities they serve, including low-income areas","Lenders to disclose APR on all loans","Banks to offer loans at below-market rates to minorities"],correct:1,explanation:"The CRA requires banks and thrifts to meet the credit needs of the communities they serve, including low- and moderate-income neighborhoods.",strategy:"CRA = banks must serve their whole community. Enacted in response to redlining."},
{id:75,category:"Finance & Mortgages",exam:"both",question:"A purchase money mortgage is:",options:["A mortgage from the seller to help finance the buyer's purchase","A government-backed loan only","A loan used exclusively for investment properties","A loan paid off at or before closing"],correct:0,explanation:"A purchase money mortgage is seller financing — the seller lends the buyer money to purchase the property, taking back a mortgage as security.",strategy:"Purchase money mortgage = seller financing. The seller becomes the lender."},
{id:76,category:"Finance & Mortgages",exam:"both",question:"'Subject to' in a real estate transaction means:",options:["The buyer assumes full personal liability for the existing mortgage","The buyer takes title while the seller's mortgage remains, but the buyer does not assume personal liability","The seller pays off the mortgage at closing","The lender approves the new buyer as the borrower"],correct:1,explanation:"Taking title 'subject to' means the existing mortgage stays in place, the buyer makes payments, but the seller remains personally liable on the loan.",strategy:"Subject to = buyer takes over payments but seller stays on the hook. Assumption = buyer takes full liability."},
{id:77,category:"Finance & Mortgages",exam:"both",question:"A wraparound mortgage involves:",options:["A second mortgage that includes the first mortgage balance","A mortgage that wraps around a property boundary","A balloon payment at the end of the term","A mortgage assumable by any buyer"],correct:0,explanation:"A wraparound mortgage is a junior loan that includes and 'wraps around' the existing first mortgage.",strategy:"Wraparound = all-inclusive. Junior lender collects combined payment and services the senior loan."},
{id:78,category:"Finance & Mortgages",exam:"both",question:"Which type of loan is backed by the full faith and credit of the federal government?",options:["Conventional conforming","Jumbo loan","VA loan","Portfolio loan"],correct:2,explanation:"VA loans are backed by the federal government. FHA loans are also government-backed.",strategy:"FHA and VA = government-backed. Conventional = not government-backed. Jumbo = exceeds conforming limits."},
{id:79,category:"Finance & Mortgages",exam:"both",question:"Discount points are best described as:",options:["A fee paid to the title company","Prepaid interest paid to the lender to reduce the interest rate","The lender's origination fee","A down payment supplement"],correct:1,explanation:"Discount points are prepaid interest paid upfront to buy down the interest rate. One point = 1% of the loan amount.",strategy:"Points = buying down the rate. More points upfront = lower rate = lower monthly payment."},
{id:80,category:"Finance & Mortgages",exam:"both",question:"A property has NOI of $54,000 and a cap rate of 6%. Estimated value?",options:["$324,000","$648,000","$900,000","$3,240,000"],correct:2,explanation:"Value = NOI ÷ Cap Rate = $54,000 ÷ 0.06 = $900,000.",strategy:"V = I ÷ R. Cover the unknown on the T-bar."},
// VALUATION & APPRAISAL (20)
{id:81,category:"Valuation & Appraisal",exam:"both",question:"An appraiser finds a comp sold for $500,000 but had a pool worth $15,000 that the subject lacks. The appraiser should:",options:["Add $15,000 to the comp","Subtract $15,000 from the comp","Add $15,000 to the subject","Make no adjustment"],correct:1,explanation:"When the comparable is superior, subtract from the comp. CBS: Comparable Better → Subtract.",strategy:"CBS/CIA: Always adjust the COMPARABLE, never the subject."},
{id:82,category:"Valuation & Appraisal",exam:"both",question:"Which appraisal approach is most appropriate for an income-producing apartment building?",options:["Sales comparison","Cost approach","Income approach","Gross rent multiplier only"],correct:2,explanation:"The income approach values property based on income generated. Primary approach for investment and commercial properties.",strategy:"Income approach = income properties. Sales comparison = residential. Cost = new/unique."},
{id:83,category:"Valuation & Appraisal",exam:"both",question:"A property with only one bedroom in a neighborhood of three-bedroom homes suffers from:",options:["Physical deterioration","External obsolescence","Functional obsolescence","Economic depreciation"],correct:2,explanation:"Functional obsolescence results from outdated or inadequate design features within the property.",strategy:"Functional = design flaw inside. External = outside forces. Physical = wear and tear."},
{id:84,category:"Valuation & Appraisal",exam:"both",question:"Reconciliation in appraisal means:",options:["Averaging the three approaches","Weighing results of all approaches to reach a final value conclusion","Choosing the highest value","Subtracting adjustments from comps"],correct:1,explanation:"Reconciliation is the appraiser's professional judgment process — not a mathematical average.",strategy:"Reconciliation ≠ averaging. The appraiser weighs reliability of each approach."},
{id:85,category:"Valuation & Appraisal",exam:"both",question:"The cost approach formula is:",options:["Land Value + Improvements – Depreciation","Sales Price – Closing Costs","NOI ÷ Cap Rate","Gross Rent × GRM"],correct:0,explanation:"The cost approach: estimate land value, add the cost to reproduce/replace improvements, then subtract all forms of depreciation.",strategy:"Cost approach = Land + Building Cost – Depreciation. Land is never depreciated."},
{id:86,category:"Valuation & Appraisal",exam:"both",question:"Plottage refers to:",options:["The total square footage of a parcel","An increase in value from combining adjacent parcels","The process of subdividing land","The value lost due to irregular shape"],correct:1,explanation:"Plottage is the increased value that results from combining two or more adjacent parcels into one larger parcel.",strategy:"Plottage = whole worth more than parts. Assemblage = the process of combining lots."},
{id:87,category:"Valuation & Appraisal",exam:"both",question:"External obsolescence is always:",options:["Curable","Incurable","Physical in nature","Located inside the property"],correct:1,explanation:"External obsolescence is caused by factors outside the property and is always incurable.",strategy:"External = outside = always incurable. Functional and physical can sometimes be curable."},
{id:88,category:"Valuation & Appraisal",exam:"both",question:"Gross Rent Multiplier (GRM) is calculated as:",options:["Monthly Rent ÷ Purchase Price","Purchase Price ÷ Monthly Gross Rent","NOI ÷ Cap Rate","Annual NOI ÷ Purchase Price"],correct:1,explanation:"GRM = Purchase Price ÷ Monthly Gross Rent. It's a quick valuation tool that ignores expenses.",strategy:"GRM = Price ÷ Rent. Simple and fast but doesn't account for operating expenses."},
{id:89,category:"Valuation & Appraisal",exam:"both",question:"Market value is best defined as:",options:["The price a seller hopes to get","The most probable price a property would sell for in an arm's-length transaction between informed parties","The appraised value set by the county","The replacement cost of the property"],correct:1,explanation:"Market value is the most probable price in a competitive, open market transaction between informed, willing buyers and sellers.",strategy:"Market value = most probable price, arm's-length, informed parties. Not listing price, not tax assessed value."},
{id:90,category:"Valuation & Appraisal",exam:"both",question:"A comparable has a two-car garage worth $12,000 and the subject has none. The appraiser should:",options:["Add $12,000 to the subject's value","Subtract $12,000 from the comparable's sale price","Add $12,000 to the comparable's sale price","Make no adjustment"],correct:1,explanation:"Comparable Better → Subtract. The comp has something the subject doesn't, so subtract from the comp.",strategy:"CBS: Comparable Better = Subtract. CIA: Comparable Inferior = Add. Always adjust the comp."},
{id:91,category:"Valuation & Appraisal",exam:"both",question:"Which appraisal approach is most appropriate for a new fire station?",options:["Sales comparison","Income approach","Cost approach","Gross rent multiplier"],correct:2,explanation:"The cost approach is best for special-use properties that rarely sell and don't generate income.",strategy:"Special-use, unique, or new properties = Cost approach. No sales comps = can't use sales comparison."},
{id:92,category:"Valuation & Appraisal",exam:"both",question:"A CMA is performed by:",options:["A licensed appraiser only","A real estate agent or broker to estimate listing price","A government assessor","A title company"],correct:1,explanation:"A CMA is performed by a real estate agent or broker to help set a listing price. It is not an appraisal.",strategy:"CMA = agent tool for pricing. Appraisal = licensed appraiser, used by lenders."},
{id:93,category:"Valuation & Appraisal",exam:"both",question:"The principle of substitution states:",options:["A buyer will pay no more for a property than the cost of an equally desirable substitute","Properties in the same area will eventually equalize in value","Value is created by the anticipation of future benefits","The highest value use is the most probable legal use"],correct:0,explanation:"The principle of substitution is the foundation of the sales comparison approach: a rational buyer will pay no more than the cost of an equivalent substitute.",strategy:"Substitution = basis for sales comparison. Why pay more if you can buy a similar home for less?"},
{id:94,category:"Valuation & Appraisal",exam:"both",question:"Highest and best use means:",options:["The use that generates the most income","The most probable legal use that is physically possible, legally permissible, financially feasible, and maximally productive","The use the current owner prefers","The use requiring the most expensive improvements"],correct:1,explanation:"Highest and best use must meet all four criteria: physically possible, legally permissible, financially feasible, and maximally productive.",strategy:"HBU must meet ALL four criteria. Profitable but not legally permitted is NOT HBU."},
{id:95,category:"Valuation & Appraisal",exam:"both",question:"Effective age of a property refers to:",options:["The calendar age from the date of construction","The age suggested by the property's condition and utility relative to similar properties","The age used for tax purposes","The age at which the property was last renovated"],correct:1,explanation:"Effective age reflects the property's actual condition, not its chronological age.",strategy:"Effective age = condition-based age. Well-maintained = lower effective age than actual age."},
{id:96,category:"Valuation & Appraisal",exam:"both",question:"Cap rates are derived from:",options:["The borrower's credit score","Market data showing the relationship between NOI and sale prices of comparable income properties","The property's appraised value divided by annual rent","The lender's required rate of return"],correct:1,explanation:"Cap rates are extracted from the market by analyzing sales of comparable income properties.",strategy:"Cap rate = market-derived. Reflects investors' required return for that property type and location."},
{id:97,category:"Valuation & Appraisal",exam:"both",question:"The principle of progression states:",options:["Lower-value properties benefit from proximity to higher-value properties","Higher-value properties are harmed by proximity to lower-value properties","Properties increase in value over time","Improvements always increase property value"],correct:0,explanation:"Progression: a lower-value property is pulled up in value by surrounding higher-value properties.",strategy:"Progression = lower benefits from higher neighbors. Regression = higher is hurt by lower neighbors."},
{id:98,category:"Valuation & Appraisal",exam:"both",question:"Which is NOT a characteristic of value (DUST)?",options:["Demand","Utility","Scarcity","Transferability"],correct:3,explanation:"DUST: Demand, Utility, Scarcity, Transferability. All four must be present for value to exist.",strategy:"Wait — all four ARE characteristics of DUST. This question tests whether you know all four. Trick: if asked what's NOT in DUST, the answer is something outside these four."},
{id:99,category:"Valuation & Appraisal",exam:"both",question:"Assemblage is best defined as:",options:["The increase in value from combining parcels","The process of combining two or more adjacent parcels under single ownership","Dividing one large parcel into smaller lots","The legal description of a property"],correct:1,explanation:"Assemblage is the process of combining parcels. Plottage is the resulting value increase.",strategy:"Assemblage = process of combining. Plottage = resulting value increase. Process vs. result."},
{id:100,category:"Valuation & Appraisal",exam:"both",question:"A property's functional obsolescence caused by a super-adequacy (over-improvement) is:",options:["Always curable","Always incurable","Sometimes curable, depending on cost vs. value gained","Not a form of depreciation"],correct:2,explanation:"A super-adequacy may or may not be curable depending on whether removal cost is justified by value gained.",strategy:"Super-adequacy = too much of something. Curable if cost to remove < value gained."},
,

// PROPERTY OWNERSHIP & LAND USE (20)
{id:101,category:"Property Ownership & Land Use",exam:"both",question:"Two sisters hold property as joint tenants with right of survivorship. One sister dies. Her interest:",options:["Passes per her will","Passes automatically to the surviving sister","Goes through probate","Splits between heirs and surviving sister"],correct:1,explanation:"Right of survivorship means the deceased's interest automatically passes to surviving joint tenants, bypassing probate.",strategy:"Right of survivorship BYPASSES probate and OVERRIDES wills."},
{id:102,category:"Property Ownership & Land Use",exam:"both",question:"Purchasing a co-op in NYC means the buyer receives:",options:["Fee simple title to the unit","A deed to the airspace","Shares in a corporation and a proprietary lease","An undivided interest in the building"],correct:2,explanation:"Co-op buyers purchase shares in a corporation. Those shares entitle them to a proprietary lease for their unit.",strategy:"Co-op = shares + proprietary lease (no deed). Condo = fee simple deed."},
{id:103,category:"Property Ownership & Land Use",exam:"both",question:"Which form of co-ownership is available only to married couples in NY?",options:["Joint tenancy","Tenancy in common","Tenancy by the entirety","Community property"],correct:2,explanation:"Tenancy by the entirety is available only to married couples in NY. Neither spouse can convey their interest without the other's consent.",strategy:"Tenancy by the entirety = married couples only. NY is NOT a community property state."},
{id:104,category:"Property Ownership & Land Use",exam:"both",question:"A homeowner has openly used a path across a neighbor's land for 12 years without permission. In NY, they may have acquired:",options:["Adverse possession","Easement by prescription","License","Easement by necessity"],correct:1,explanation:"Easement by prescription creates a use right through open, continuous, hostile use for 10 years in NY — not ownership.",strategy:"Prescription = use right. Adverse possession = ownership. Both require open/continuous/hostile use."},
{id:105,category:"Property Ownership & Land Use",exam:"both",question:"A variance allows a property owner to:",options:["Permanently rezone land","Use property in a way that deviates from current zoning","Override a deed restriction","Transfer air rights to an adjacent parcel"],correct:1,explanation:"A variance is permission to deviate from specific zoning requirements due to hardship. It does not rezone the land.",strategy:"Variance ≠ rezoning. Variance is an individual exception to zoning."},
{id:106,category:"Property Ownership & Land Use",exam:"both",question:"Fee simple absolute is best described as:",options:["Ownership that expires after a set period","The highest form of real property ownership with no conditions","Ownership shared with the government","A leasehold interest in property"],correct:1,explanation:"Fee simple absolute is the most complete form of real property ownership — unlimited duration, freely transferable, no conditions.",strategy:"Fee simple absolute = maximum ownership. No conditions, no time limits, fully transferable."},
{id:107,category:"Property Ownership & Land Use",exam:"both",question:"A life estate grants ownership:",options:["For a set number of years","For the duration of someone's life, after which title passes to a remainderman","In perpetuity to the owner's heirs","Subject to a mortgage being paid off"],correct:1,explanation:"A life estate lasts for the duration of a specified person's life. Upon death, title passes to the remainderman.",strategy:"Life estate = ownership for life only. Life tenant cannot devise it by will."},
{id:108,category:"Property Ownership & Land Use",exam:"both",question:"An easement in gross benefits:",options:["An adjacent property","A specific individual or entity, not a property","The general public only","The government exclusively"],correct:1,explanation:"An easement in gross is a personal right — it benefits a person or entity, not an adjacent property.",strategy:"Easement appurtenant = benefits adjacent land. Easement in gross = benefits a person/entity."},
{id:109,category:"Property Ownership & Land Use",exam:"both",question:"Which is a government limitation on private property?",options:["Deed restriction","Easement appurtenant","Zoning ordinance","Restrictive covenant"],correct:2,explanation:"Zoning ordinances are government (public) limitations on land use. Deed restrictions and covenants are private limitations.",strategy:"Public = government (zoning, eminent domain, taxation, police power). Private = deeds, covenants, easements."},
{id:110,category:"Property Ownership & Land Use",exam:"both",question:"Police power in real estate refers to:",options:["Law enforcement access to private property","The government's right to regulate property use for public health, safety, and welfare","The power to take property through eminent domain","A landlord's right to enter a rental unit"],correct:1,explanation:"Police power is the government's right to regulate land use without compensation — including zoning and building codes.",strategy:"Police power = regulate (no payment). Eminent domain = take (must pay). Both are government powers."},
{id:111,category:"Property Ownership & Land Use",exam:"both",question:"Adverse possession in NY requires all of the following EXCEPT:",options:["Open and notorious use","Continuous use for 10 years","Payment of property taxes (in some cases)","Permission from the owner"],correct:3,explanation:"Adverse possession requires open, notorious, continuous, hostile (without permission), and actual use. Permission destroys the hostile-use requirement.",strategy:"Permission kills adverse possession. If the owner gives permission, the use is no longer hostile."},
{id:112,category:"Property Ownership & Land Use",exam:"both",question:"A deed restriction that prevents commercial use of a property:",options:["Expires after 10 years by law","Runs with the land and binds future owners","Is only enforceable against the original buyer","Is a form of government zoning"],correct:1,explanation:"Deed restrictions (restrictive covenants) run with the land — they bind all future owners, not just the original buyer.",strategy:"Deed restrictions run with the land. Future buyers are bound even if unaware."},
{id:113,category:"Property Ownership & Land Use",exam:"both",question:"What is a leasehold estate?",options:["Ownership of property in fee simple","The right to use and occupy property for a specified period under a lease","An ownership interest that lasts for someone's lifetime","A fractional ownership interest in a vacation property"],correct:1,explanation:"A leasehold estate is a tenant's right to possess and use property for a defined period under a lease — not ownership.",strategy:"Leasehold = tenant's interest (right to possess). Freehold = ownership interest (title)."},
{id:114,category:"Property Ownership & Land Use",exam:"both",question:"The four government powers over real estate (PETE) stand for:",options:["Purchase, Easement, Title, Encumbrance","Police power, Eminent domain, Taxation, Escheat","Property, Equity, Transfer, Encumbrance","Possession, Easement, Taxation, Escheat"],correct:1,explanation:"PETE: Police power (regulate), Eminent domain (take with compensation), Taxation (assess), Escheat (property goes to state when owner dies without heirs).",strategy:"PETE = four government powers. These override private property rights."},
{id:115,category:"Property Ownership & Land Use",exam:"both",question:"Escheat means:",options:["The government takes property for public use","Property reverts to the state when the owner dies without heirs or a will","A forced sale of property to pay taxes","The right to use another's property"],correct:1,explanation:"Escheat is the government's power to claim property when the owner dies intestate with no legal heirs.",strategy:"Escheat = state gets property of person who dies with no heirs and no will."},
{id:116,category:"Property Ownership & Land Use",exam:"both",question:"A nonconforming use is:",options:["A use that violates current zoning but existed legally before the zoning change","Any use that requires a variance","A use that violates deed restrictions","A temporary use permit"],correct:0,explanation:"A nonconforming use was legal when established but doesn't conform to current zoning. Generally allowed to continue but may not be expanded.",strategy:"Nonconforming = grandfathered in. Was legal before, so it can continue — but not expand."},
{id:117,category:"Property Ownership & Land Use",exam:"both",question:"Air rights refer to:",options:["The right to use the airspace above one's property","Government flight regulations over private property","The right to install HVAC systems","A license to operate a drone over someone else's land"],correct:0,explanation:"Air rights are the property rights to the space above a parcel of land. They can be sold separately — common in NYC for height transfers.",strategy:"Air rights = space above the property. In NYC, unused air rights can be sold to adjacent parcels to build higher."},
{id:118,category:"Property Ownership & Land Use",exam:"both",question:"Mineral rights are:",options:["Only part of commercial property ownership","Real property ownership unless severed and conveyed separately","Personal property exclusively","Federal land grants only"],correct:1,explanation:"Mineral rights are part of real property ownership. They can be severed — sold or leased separately from surface rights.",strategy:"Mineral rights = real property unless severed. A seller can convey surface rights but keep mineral rights."},
{id:119,category:"Property Ownership & Land Use",exam:"both",question:"Which of the following is a freehold estate?",options:["Month-to-month tenancy","Tenancy for years","Fee simple absolute","Tenancy at will"],correct:2,explanation:"Freehold estates involve ownership (indefinite duration). Fee simple absolute is the most common.",strategy:"Freehold = ownership (indefinite). Leasehold = possession under lease (defined term)."},
{id:120,category:"Property Ownership & Land Use",exam:"both",question:"Which best describes tenancy in common?",options:["Equal shares required; right of survivorship","Unequal shares allowed; no right of survivorship; interest passes to heirs","Available only to married couples","Requires four unities: time, title, interest, possession"],correct:1,explanation:"Tenancy in common allows unequal shares, has no right of survivorship, and each co-owner's interest passes to their heirs.",strategy:"Tenancy in common = unequal shares OK, no survivorship, heirs get your share. Opposite of joint tenancy."},
// DEEDS & TITLE (20)
{id:121,category:"Deeds & Title",exam:"both",question:"Which deed offers the buyer the least protection?",options:["General warranty deed","Special warranty deed","Bargain and sale deed","Quitclaim deed"],correct:3,explanation:"A quitclaim deed offers no warranties — the grantor conveys whatever interest they have, which may be nothing.",strategy:"Deed protection: General Warranty > Special Warranty > Bargain & Sale > Quitclaim (least)."},
{id:122,category:"Deeds & Title",exam:"both",question:"A buyer purchases property without checking public records. A prior mortgage lien is on record. Is the buyer bound?",options:["No — they had no actual notice","Yes — constructive notice means they're presumed to know what's recorded","Only if lender notified them","Only if recorded within the last year"],correct:1,explanation:"Constructive notice: recorded documents are presumed known by all. Ignorance of public records is not a defense.",strategy:"Recorded = constructive notice. You're legally presumed to know what's in the public record."},
{id:123,category:"Deeds & Title",exam:"both",question:"In NY, a Bargain and Sale deed is most commonly used in:",options:["Standard residential sales","Family gift transfers","Foreclosure sales","Commercial leases"],correct:2,explanation:"Bargain and Sale deeds are common in NY foreclosure and tax sales, where the grantor cannot guarantee clear title.",strategy:"Bargain & Sale = NY foreclosures/tax sales. General Warranty = standard residential."},
{id:124,category:"Deeds & Title",exam:"both",question:"For a deed to be valid, it must be all of the following EXCEPT:",options:["In writing","Signed by the grantor","Delivered and accepted","Recorded in the county clerk's office"],correct:3,explanation:"Recording is not required for a deed to be valid between the parties — but it is essential for protection against third parties.",strategy:"Recording ≠ validity. A deed is valid upon delivery and acceptance. Recording provides constructive notice."},
{id:125,category:"Deeds & Title",exam:"both",question:"A general warranty deed contains which covenants?",options:["Seisin, quiet enjoyment, warranty, and further assurance","Only the covenant of seisin","Only the covenant against encumbrances","No covenants — it relies on state law"],correct:0,explanation:"A general warranty deed contains covenants of seisin, quiet enjoyment, against encumbrances, warranty, and further assurance — covering ALL time.",strategy:"General warranty = full set of covenants covering ALL time. Special warranty = only during grantor's ownership."},
{id:126,category:"Deeds & Title",exam:"both",question:"Title insurance protects against:",options:["Future zoning changes","Physical damage to the property","Defects in title that existed before the policy was issued","Property tax increases"],correct:2,explanation:"Title insurance protects against undiscovered defects in title that existed before the policy date — such as forged deeds or unknown heirs.",strategy:"Title insurance = past defects. Hazard insurance = future physical damage. They cover different things."},
{id:127,category:"Deeds & Title",exam:"both",question:"A lender's title insurance policy protects:",options:["The buyer","The lender only, up to the loan amount","Both buyer and lender","The seller"],correct:1,explanation:"A lender's title policy protects the lender up to the loan amount. A separate owner's policy is needed for the buyer.",strategy:"Lender's policy = lender's protection. Owner's policy = buyer's protection. Both may be purchased at closing."},
{id:128,category:"Deeds & Title",exam:"both",question:"The granting clause in a deed:",options:["Describes the property boundaries","Contains the words of conveyance transferring title","Lists encumbrances on the property","Identifies the purchase price"],correct:1,explanation:"The granting clause contains the operative words of conveyance — such as 'grant and convey' — that transfer the property from grantor to grantee.",strategy:"Granting clause = words that transfer title. It's the most essential clause in a deed."},
{id:129,category:"Deeds & Title",exam:"both",question:"Chain of title refers to:",options:["A requirement that title be free of all liens","The historical sequence of property ownership from the original grant to the present owner","The order in which creditors are paid","A survey of the property's boundaries"],correct:1,explanation:"Chain of title is the recorded history of all conveyances of a property from the original title holder to the current owner.",strategy:"Chain of title = ownership history. Gaps in the chain = cloud on title."},
{id:130,category:"Deeds & Title",exam:"both",question:"A cloud on title refers to:",options:["Unclear property boundaries","An outstanding claim or encumbrance that affects the clarity of title","An unpaid property tax lien specifically","A lien from a prior mortgage specifically"],correct:1,explanation:"A cloud on title is any claim, encumbrance, or defect that casts doubt on the clarity of ownership.",strategy:"Cloud = anything that makes title uncertain. Resolved through a quiet title action."},
{id:131,category:"Deeds & Title",exam:"both",question:"A quiet title action is used to:",options:["Prevent neighbors from making noise","Legally establish or clear up ownership disputes in court","Force a seller to close","Remove a tenant from a property"],correct:1,explanation:"A quiet title action is a court proceeding to establish the true owner of a property or remove adverse claims from the title.",strategy:"Quiet title = court action to clean up ownership disputes. Clears clouds on title."},
{id:132,category:"Deeds & Title",exam:"both",question:"Which of the following is an involuntary lien?",options:["Mortgage","Mechanic's lien","Deed of trust","Easement"],correct:1,explanation:"A mechanic's lien is placed without the property owner's consent when a contractor is unpaid. Mortgages are voluntary liens.",strategy:"Voluntary lien = owner chose it (mortgage). Involuntary = placed without consent (mechanic's, tax lien)."},
{id:133,category:"Deeds & Title",exam:"both",question:"Property taxes are which type of lien?",options:["Specific voluntary lien","General involuntary lien","Specific involuntary lien","General voluntary lien"],correct:2,explanation:"Property taxes create a specific (on that one property), involuntary (without owner consent) lien that has priority over most other liens.",strategy:"Tax lien = specific (one property) + involuntary (no consent) + super-priority."},
{id:134,category:"Deeds & Title",exam:"both",question:"Which of the following has the highest priority in a foreclosure?",options:["First mortgage","Mechanic's lien","Property tax lien","Second mortgage"],correct:2,explanation:"Property tax liens generally have super-priority — they take precedence over all other liens, including mortgages.",strategy:"Tax liens = first in priority, always. 'The government always gets paid first.'"},
{id:135,category:"Deeds & Title",exam:"both",question:"A lis pendens is:",options:["A type of deed","A notice of pending litigation affecting title to real property","A lien for unpaid HOA dues","A survey notation"],correct:1,explanation:"Lis pendens (Latin: 'lawsuit pending') is recorded notice that a legal action affecting title to real property is currently pending in court.",strategy:"Lis pendens = lawsuit on the property. Buyers beware — purchasing during pending litigation is risky."},
{id:136,category:"Deeds & Title",exam:"both",question:"Recording a deed primarily serves to:",options:["Make the deed legally valid","Provide constructive notice of ownership to the world","Transfer physical possession of the property","Establish the purchase price for tax purposes"],correct:1,explanation:"Recording provides constructive notice — the world is presumed to know of recorded interests.",strategy:"Recording = constructive notice = protection against future buyers and creditors."},
{id:137,category:"Deeds & Title",exam:"both",question:"Which is NOT a valid legal description method?",options:["Metes and bounds","Lot and block (recorded plat)","Street address","Government rectangular survey"],correct:2,explanation:"A street address is not a legally sufficient property description. Valid methods include metes and bounds, lot and block, and government rectangular survey.",strategy:"Street address ≠ legal description. Deeds require metes and bounds, lot and block, or rectangular survey."},
{id:138,category:"Deeds & Title",exam:"both",question:"A special warranty deed warrants title against defects arising:",options:["From any time in history","Only during the grantor's period of ownership","From the original land grant","Only from recorded encumbrances"],correct:1,explanation:"A special warranty deed only protects against title defects that arose during the grantor's ownership.",strategy:"Special warranty = during my ownership only. General warranty = all time, including before I owned it."},
{id:139,category:"Deeds & Title",exam:"both",question:"The habendum clause in a deed defines:",options:["The purchase price","The extent of the ownership interest being conveyed","The property's legal description","The names of the parties"],correct:1,explanation:"The habendum clause ('to have and to hold') defines the type and extent of the ownership interest being transferred.",strategy:"Habendum = 'to have and to hold' = what kind of ownership you're getting (fee simple, life estate, etc)."},
{id:140,category:"Deeds & Title",exam:"both",question:"Which of the following requires a deed to be valid in NY?",options:["Two witnesses","Notarization","Grantor's signature","Recording within 30 days"],correct:2,explanation:"A deed must be signed (executed) by the grantor to be valid. Notarization is required for recording, not for validity between parties.",strategy:"Grantor signs, grantee accepts. Notarization is needed for recording — not for the deed itself to be valid."},
// BROKER LICENSE LAW (20)
{id:141,category:"Broker License Law",exam:"broker",question:"A broker deposits client earnest money into the firm's operating account. This is:",options:["Conversion","Commingling","Hypothecation","Subordination"],correct:1,explanation:"Commingling = mixing client funds with the broker's own funds. Illegal; grounds for license revocation.",strategy:"Commingling = mixing. Conversion = stealing (using client money personally). Both illegal; conversion is criminal."},
{id:142,category:"Broker License Law",exam:"broker",question:"How many hours of qualifying education are required for a NY broker's license?",options:["45 hours","75 hours","120 hours","180 hours"],correct:2,explanation:"NY requires 120 hours of qualifying real estate education for broker licensure.",strategy:"Salesperson = 75 hours. Broker = 120 hours. CE renewal = 22.5 hours every 2 years."},
{id:143,category:"Broker License Law",exam:"broker",question:"Which NY state agency regulates real estate licensees?",options:["Department of Finance","Division of Housing and Community Renewal","Department of State","Office of the Attorney General"],correct:2,explanation:"The NY Department of State (DOS) licenses and regulates real estate brokers and salespersons.",strategy:"NY DOS = real estate licenses. Division of Licensing Services handles all RE licensee regulation."},
{id:144,category:"Broker License Law",exam:"broker",question:"A broker produces a ready, willing, and able buyer. The seller then refuses to sell. The broker:",options:["Forfeits the commission","May still be entitled to the commission","Must return the deposit to the buyer","Must get a court order to collect"],correct:1,explanation:"Commission is generally earned when a ready, willing, and able buyer is produced — even if the seller refuses, unless the contract says otherwise.",strategy:"Broker earns at RWA buyer production — not at closing. Seller backing out doesn't erase the earned commission."},
{id:145,category:"Broker License Law",exam:"broker",question:"A salesperson's license is issued July 1, 2023. When must she complete CE for first renewal?",options:["July 1, 2024","July 1, 2025","December 31, 2025","July 1, 2026"],correct:1,explanation:"NY real estate licenses renew every 2 years. 22.5 hours of CE must be completed within that period.",strategy:"License issued July 2023 → first renewal July 2025. CE must be done before the renewal date."},
{id:146,category:"Broker License Law",exam:"broker",question:"A NY real estate salesperson may NOT:",options:["Negotiate a listing agreement on behalf of the broker","Accept a commission directly from a seller","Show properties to buyers","Prepare a comparative market analysis"],correct:1,explanation:"Salespersons may only receive compensation through their broker — never directly from a buyer, seller, or another party.",strategy:"Salesperson = compensation only through broker. Direct payment from the public = violation."},
{id:147,category:"Broker License Law",exam:"broker",question:"The NY broker exam must be passed and the application submitted within:",options:["6 months of passing","1 year of passing","2 years of passing","5 years of passing"],correct:2,explanation:"In NY, a candidate must apply for a broker's license within 2 years of passing the broker exam.",strategy:"Pass broker exam → apply within 2 years or start over."},
{id:148,category:"Broker License Law",exam:"broker",question:"When a salesperson moves to a new firm, the salesperson's license:",options:["Is automatically transferred to the new broker","Must be returned to DOS and a new license obtained","Must be transferred through the DOS with the new broker's sponsorship","Expires immediately"],correct:2,explanation:"A salesperson's license is held through their sponsoring broker. To change firms, the salesperson must transfer their license through the DOS to the new broker.",strategy:"License transfer = go through DOS with new broker's sponsorship. Can't just walk over with your license."},
{id:149,category:"Broker License Law",exam:"broker",question:"An unlicensed assistant may legally:",options:["Show properties to prospective buyers","Negotiate lease terms on behalf of the broker","Prepare and deliver contracts for signature","Perform general administrative tasks such as scheduling and filing"],correct:3,explanation:"Unlicensed assistants may only perform administrative, non-licensed tasks — no showing property, negotiating, or discussing terms.",strategy:"Unlicensed = admin only. Anything requiring a license (showing, negotiating, discussing terms) requires a license."},
{id:150,category:"Broker License Law",exam:"broker",question:"A broker who operates under an assumed name (DBA) must:",options:["Register the assumed name with the DOS","Only use the name on business cards","Keep it separate from the licensed broker name at all times","Obtain a separate license for the DBA"],correct:0,explanation:"A broker who uses a trade name (DBA) must register that name with the NY DOS.",strategy:"DBA = must register with DOS. Consumers must be able to identify the licensed entity behind the trade name."},
{id:151,category:"Broker License Law",exam:"broker",question:"A managing broker is responsible for:",options:["Only their own transactions","The conduct of all affiliated salespersons","Setting commission rates for the market","Filing tax returns for affiliated agents"],correct:1,explanation:"A managing broker is legally responsible for supervising all salespersons and associate brokers affiliated with their firm.",strategy:"Broker = legally responsible for salesperson conduct. Salesperson violations can result in broker sanctions too."},
{id:152,category:"Broker License Law",exam:"broker",question:"What is the minimum age to apply for a NY real estate salesperson license?",options:["16","18","19","21"],correct:1,explanation:"The minimum age to obtain a NY real estate salesperson license is 18 years old.",strategy:"Salesperson = 18+. Broker = 20+. Know both age requirements."},
{id:153,category:"Broker License Law",exam:"broker",question:"Which of the following is grounds for license revocation in NY?",options:["Failing to renew on time","Making a misrepresentation in a transaction","Having a bankruptcy on record","Representing both buyer and seller with consent"],correct:1,explanation:"Misrepresentation in a real estate transaction is a serious violation that can result in license suspension or revocation.",strategy:"Revocation grounds: fraud, misrepresentation, commingling, conversion, discrimination, failing to account."},
{id:154,category:"Broker License Law",exam:"broker",question:"A referral fee paid to an unlicensed person for referring a real estate client is:",options:["Legal if under $500","Legal with the broker's written permission","Illegal — referral fees may only be paid to licensed individuals","Legal between family members"],correct:2,explanation:"Referral fees for real estate services may only be paid to licensed real estate professionals. Paying an unlicensed person for a referral is illegal.",strategy:"Unlicensed person + referral fee = illegal. Always. No dollar amount makes it legal."},
{id:155,category:"Broker License Law",exam:"broker",question:"A NY broker must keep transaction records for a minimum of:",options:["1 year","2 years","3 years","5 years"],correct:2,explanation:"NY real estate brokers must retain transaction records for a minimum of 3 years.",strategy:"NY record retention = 3 years minimum. Keep everything — transaction files, escrow records, correspondence."},
{id:156,category:"Broker License Law",exam:"broker",question:"A salesperson who acts as a buyer in a transaction where their broker represents the seller must:",options:["Automatically withdraw from the transaction","Disclose their licensee status to all parties","Only disclose to the seller","Take no special action"],correct:1,explanation:"A licensee who is a party to a transaction must disclose their licensed status to all parties in writing.",strategy:"Licensee buying or selling = must disclose licensee status. Applies to all sides of the transaction."},
{id:157,category:"Broker License Law",exam:"broker",question:"A designated broker is best described as:",options:["A broker who only works with developers","The individual broker responsible for the actions of an entire real estate firm","A broker who handles only commercial transactions","An associate broker who manages one office location"],correct:1,explanation:"A designated broker (or responsible broker) is the licensed broker legally responsible for the overall operation and conduct of a real estate firm.",strategy:"Designated broker = top of the firm's license hierarchy. Ultimate responsibility for everyone under that license."},
{id:158,category:"Broker License Law",exam:"broker",question:"A salesperson receives a commission offer directly from the seller at closing. The salesperson should:",options:["Accept it — they earned it","Decline and direct all compensation through the broker","Accept with the broker's verbal approval","Accept only if it equals the agreed split"],correct:1,explanation:"Salespersons may only receive compensation through their sponsoring broker — never directly from the public.",strategy:"Salesperson compensation = broker only. Direct payment from public = license violation."},
{id:159,category:"Broker License Law",exam:"broker",question:"NY law requires that all advertising by a real estate licensee:",options:["Include the agent's photo","Clearly identify the licensed broker or brokerage","Include the MLS number","Be approved by the DOS before publication"],correct:1,explanation:"All real estate advertising must clearly identify the licensed broker or brokerage — not just the salesperson's name.",strategy:"Advertising = broker name must appear. Salesperson-only ads without broker identification violate NY law."},
{id:160,category:"Broker License Law",exam:"broker",question:"The key tax distinction between an employee and an independent contractor is:",options:["Independent contractors pay no taxes","Employees receive W-2s with withholding; ICs receive 1099s and pay self-employment tax","Independent contractors earn higher commissions by law","There is no distinction for real estate licensees"],correct:1,explanation:"Employees get W-2s. Independent contractors get 1099s and are responsible for self-employment tax. Most agents are ICs.",strategy:"Most agents = independent contractors = 1099 = self-employment tax."},
// REAL ESTATE MATH (20)
{id:161,category:"Real Estate Math",exam:"both",question:"Home sells for $520,000. Commission 5%, split equally. Listing salesperson gets 55% of broker's share. What does she earn?",options:["$7,150","$14,300","$7,865","$8,450"],correct:0,explanation:"$520,000 × 5% = $26,000. ÷2 = $13,000/broker. × 55% = $7,150.",strategy:"Work total → broker share → salesperson share. Don't skip steps."},
{id:162,category:"Real Estate Math",exam:"both",question:"Closing April 10. Annual taxes $4,320, paid in arrears. Seller pays through closing day. 360-day year. Seller owes:",options:["$1,080","$1,200","$1,140","$1,020"],correct:1,explanation:"Daily: $4,320 ÷ 360 = $12. Days: Jan(30)+Feb(30)+Mar(30)+Apr 1-10(10) = 100. $12 × 100 = $1,200.",strategy:"Proration: (1) daily rate, (2) count days, (3) multiply."},
{id:163,category:"Real Estate Math",exam:"both",question:"A rectangular lot is 150 ft deep and 75 ft wide. Square footage?",options:["1,125","11,250","450","2,250"],correct:1,explanation:"Area = 150 × 75 = 11,250 sq ft.",strategy:"Area = L × W. Double-check zeros — off by a decimal is a common trap."},
{id:164,category:"Real Estate Math",exam:"both",question:"A home purchased for $280,000 appreciated 15%. What is it worth now?",options:["$295,000","$295,500","$322,000","$296,000"],correct:2,explanation:"$280,000 × 1.15 = $322,000.",strategy:"New Value = Original × (1 + rate). Add the gain back to the original."},
{id:165,category:"Real Estate Math",exam:"both",question:"A property is worth $600,000 after appreciating 20%. Original price?",options:["$480,000","$500,000","$520,000","$540,000"],correct:1,explanation:"$600,000 ÷ 1.20 = $500,000.",strategy:"To find original: Current Value ÷ (1 + rate). Don't subtract the percentage — divide."},
{id:166,category:"Real Estate Math",exam:"both",question:"Commercial property generates $96,000 NOI. Buyer requires 8% return. Maximum price?",options:["$768,000","$1,200,000","$800,000","$880,000"],correct:1,explanation:"Value = NOI ÷ Cap Rate = $96,000 ÷ 0.08 = $1,200,000.",strategy:"V = I ÷ R. Higher cap rate = lower price for same income."},
{id:167,category:"Real Estate Math",exam:"both",question:"A borrower takes a $360,000 loan on a $400,000 home. LTV?",options:["80%","85%","90%","95%"],correct:2,explanation:"$360,000 ÷ $400,000 = 90% LTV. PMI is required.",strategy:"LTV = Loan ÷ Value. Above 80% = PMI on conventional loans."},
{id:168,category:"Real Estate Math",exam:"both",question:"Annual taxes $5,400. Daily proration rate (360-day year)?",options:["$10","$15","$18","$20"],correct:1,explanation:"$5,400 ÷ 360 = $15 per day.",strategy:"Annual ÷ 360 = daily rate. Always the first step in any proration problem."},
{id:169,category:"Real Estate Math",exam:"both",question:"A home appreciated 12% and is now worth $448,000. Original price?",options:["$392,000","$400,000","$404,000","$396,000"],correct:1,explanation:"$448,000 ÷ 1.12 = $400,000.",strategy:"To find original after appreciation: Current ÷ (1 + rate)."},
{id:170,category:"Real Estate Math",exam:"both",question:"Lot is 220 ft × 396 ft. How many acres?",options:["1 acre","2 acres","3 acres","4 acres"],correct:1,explanation:"220 × 396 = 87,120 sq ft ÷ 43,560 = 2 acres.",strategy:"1 acre = 43,560 sq ft. Divide total sq ft by 43,560."},
{id:171,category:"Real Estate Math",exam:"both",question:"A property sells for $750,000. Broker charges 6%. Listing and buyer's broker split 50/50. Listing broker receives:",options:["$22,500","$45,000","$15,000","$9,000"],correct:0,explanation:"$750,000 × 6% = $45,000. Split 50/50 = $22,500 for listing broker.",strategy:"Total commission first, then split. $750K × 6% = $45K. Half = $22,500."},
{id:172,category:"Real Estate Math",exam:"both",question:"A buyer puts 10% down on a $420,000 home. What is the loan amount?",options:["$378,000","$380,000","$42,000","$392,000"],correct:0,explanation:"10% down = $42,000. Loan = $420,000 – $42,000 = $378,000.",strategy:"Down payment = Price × %. Loan = Price – Down Payment."},
{id:173,category:"Real Estate Math",exam:"both",question:"A property's GRM is 120 and it rents for $2,500/month. Estimated value?",options:["$250,000","$300,000","$2,500","$3,000,000"],correct:1,explanation:"Value = GRM × Monthly Rent = 120 × $2,500 = $300,000.",strategy:"GRM formula: Value = GRM × Rent. Or GRM = Price ÷ Rent."},
{id:174,category:"Real Estate Math",exam:"both",question:"A salesperson sells a $325,000 home. Commission is 5%. Salesperson receives 60% of the total commission. What does she earn?",options:["$9,750","$16,250","$6,500","$8,125"],correct:0,explanation:"$325,000 × 5% = $16,250. × 60% = $9,750.",strategy:"Here the salesperson gets % of total, not of broker's share. Read carefully."},
{id:175,category:"Real Estate Math",exam:"both",question:"A property was depreciated at $8,000/year for 5 years. Original value $200,000. Book value now?",options:["$160,000","$175,000","$165,000","$140,000"],correct:0,explanation:"$8,000 × 5 years = $40,000 depreciation. $200,000 – $40,000 = $160,000.",strategy:"Book value = Original cost – Accumulated depreciation."},
{id:176,category:"Real Estate Math",exam:"both",question:"A 2,400 sq ft home sold for $360,000. Price per square foot?",options:["$125","$140","$150","$160"],correct:2,explanation:"$360,000 ÷ 2,400 = $150/sq ft.",strategy:"Price per sq ft = Total Price ÷ Square Footage."},
{id:177,category:"Real Estate Math",exam:"both",question:"A triangular lot has a base of 200 ft and a height of 150 ft. Area?",options:["30,000 sq ft","15,000 sq ft","20,000 sq ft","25,000 sq ft"],correct:1,explanation:"Area of triangle = ½ × base × height = ½ × 200 × 150 = 15,000 sq ft.",strategy:"Triangle area = ½ × B × H. Always divide by 2."},
{id:178,category:"Real Estate Math",exam:"both",question:"A property has an asking price of $485,000 and sells for 97% of asking. Sale price?",options:["$470,450","$470,050","$480,000","$471,000"],correct:0,explanation:"$485,000 × 0.97 = $470,450.",strategy:"Sale price = Asking × % of asking. Convert % to decimal first."},
{id:179,category:"Real Estate Math",exam:"both",question:"A buyer secures a $240,000 mortgage at 7% interest. First month's interest payment?",options:["$1,400","$16,800","$1,200","$2,000"],correct:0,explanation:"Annual interest: $240,000 × 7% = $16,800. Monthly: $16,800 ÷ 12 = $1,400.",strategy:"Monthly interest = Loan × Annual rate ÷ 12. Applies only to the first month before any principal is paid."},
{id:180,category:"Real Estate Math",exam:"both",question:"Closing is June 15. Annual insurance of $1,800 was prepaid by seller for full year starting January 1. Buyer gets credit for unused portion. How much?",options:["$900","$975","$862.50","$1,012.50"],correct:1,explanation:"Daily: $1,800 ÷ 360 = $5/day. Buyer's days (June 16–Dec 31): Jun(15)+Jul(30)+Aug(30)+Sep(30)+Oct(30)+Nov(30)+Dec(30) = 195 days. $5 × 195 = $975.",strategy:"Prepaid item: count remaining days after closing day. Buyer gets credit for unused prepaid days."},
// TEST STRATEGY & TRICKY QUESTIONS (20)
{id:181,category:"Test Strategy & Tricky Questions",exam:"both",question:"A question asks what an agent 'should' do when receiving a below-list-price offer. The best answer is:",options:["Reject it immediately to protect the seller","Present it to the seller promptly and without delay","Advise the buyer the offer is too low","Inform the seller verbally and submit a counteroffer automatically"],correct:1,explanation:"Agents must present ALL offers to the seller promptly — regardless of price. Filtering or delaying offers violates the agent's duty.",strategy:"'Should the agent' questions: fiduciary duty answers are almost always right. Present all offers promptly."},
{id:182,category:"Test Strategy & Tricky Questions",exam:"both",question:"When a question uses the word 'EXCEPT,' you should:",options:["Pick the answer most related to the topic","Pick the one answer that does NOT fit the pattern of the others","Guess the middle answer","Skip and come back"],correct:1,explanation:"EXCEPT questions ask for the one item that doesn't belong. Find the three that fit, and the one left over is your answer.",strategy:"EXCEPT = find the odd one out. Eliminate the three that belong; the remaining one is correct."},
{id:183,category:"Test Strategy & Tricky Questions",exam:"both",question:"A question asks which statement is 'most accurate.' This means:",options:["All answers are completely wrong except one","Two or more answers may be partially correct; pick the most complete and precise one","The first answer is always most accurate","Accuracy questions can be skipped"],correct:1,explanation:"'Most accurate' signals that multiple answers may be partially correct. You need the most complete and precise one.",strategy:"Most accurate = pick the most complete answer. Not just partially true — most fully and precisely true."},
{id:184,category:"Test Strategy & Tricky Questions",exam:"both",question:"Answer choices say 'always' and 'generally.' Which word signals the SAFER answer in RE law?",options:["Always — it's more definitive","Generally — because real estate law has many exceptions","They are equally reliable","It depends on the topic"],correct:1,explanation:"Real estate law has many exceptions. Answers using 'always' or 'never' are usually wrong.",strategy:"Absolutes (always, never) = usually wrong. Qualifiers (generally, typically, may) = usually safer."},
{id:185,category:"Test Strategy & Tricky Questions",exam:"both",question:"You're down to two answers on a Fair Housing question. One is more consumer-protective. You should:",options:["Choose the less restrictive answer to avoid liability","Choose the more consumer-protective answer","Flip a coin","Always choose the longer answer"],correct:1,explanation:"NY exam writers lean toward consumer protection. When two answers are close, the most protective is usually correct.",strategy:"Fair Housing tie-breaker: pick the most protective answer for the consumer."},
{id:186,category:"Test Strategy & Tricky Questions",exam:"both",question:"An agent's duty to the PRINCIPAL vs. CUSTOMER differs mainly in that:",options:["There is no meaningful difference","The principal gets fiduciary duties; the customer gets honest and fair dealing only","Customers are owed more duty because they're unrepresented","The principal gets fewer protections because they signed an agreement"],correct:1,explanation:"The agent owes fiduciary duties (COLDAC) to the principal (client) and only honest/fair dealing to a customer.",strategy:"Principal = fiduciary. Customer = honest dealing. Always distinguish who is the client vs. the other party."},
{id:187,category:"Test Strategy & Tricky Questions",exam:"both",question:"A question that asks what a licensee 'must' do is asking about:",options:["What is optional","A legal or ethical requirement","Best practice only","What is common in the market"],correct:1,explanation:"'Must' signals a legal or regulatory requirement — not a suggestion or best practice.",strategy:"Must = mandatory. Should = recommended. May = optional. These words change the entire meaning."},
{id:188,category:"Test Strategy & Tricky Questions",exam:"both",question:"A seller tells an agent the basement floods but asks the agent not to disclose it. The agent should:",options:["Honor the seller's request — the seller is the principal","Disclose the material defect to buyers despite the instruction","Only disclose if the buyer specifically asks about the basement","Disclose only in writing, not verbally"],correct:1,explanation:"Material defects must be disclosed to buyers. This overrides confidentiality.",strategy:"Material defect = must disclose. Confidentiality never covers concealing material defects. Period."},
{id:189,category:"Test Strategy & Tricky Questions",exam:"both",question:"The term 'arm's-length transaction' means:",options:["The buyer and seller are far apart geographically","Both parties are unrelated, acting independently, and in their own self-interest","The transaction closes in less than 30 days","A short sale transaction"],correct:1,explanation:"An arm's-length transaction is one where buyer and seller act independently, have no special relationship, and are each seeking the best deal.",strategy:"Arm's-length = no special relationship, independent parties. NOT arm's-length = family members, related companies."},
{id:190,category:"Test Strategy & Tricky Questions",exam:"both",question:"You don't know an answer and need to guess. Which strategy is best?",options:["Always choose C","Choose the longest answer","Eliminate clearly wrong answers first, then choose the most legally or ethically sound remaining option","Never guess — leave it blank"],correct:2,explanation:"In NY, there's no penalty for guessing. Eliminate wrong answers to improve your odds, then choose the most legally/ethically correct of what remains.",strategy:"No penalty for guessing in NY. Eliminate, then pick most legally/ethically sound. Never leave blank."},
{id:191,category:"Test Strategy & Tricky Questions",exam:"both",question:"A question about what an agent 'may' do is asking about:",options:["A mandatory action","A permitted but not required action","Something that is illegal","A best practice only"],correct:1,explanation:"'May' signals permissive language — the action is allowed but not required.",strategy:"May = optional/permitted. Must/Shall = required. Should = recommended. These words change the entire meaning."},
{id:192,category:"Test Strategy & Tricky Questions",exam:"both",question:"An agent is asked whether a nearby factory will affect the neighborhood. The best response is:",options:["Give their personal opinion based on market experience","Refer the buyer to appropriate governmental agencies and experts","Tell the buyer the factory won't affect value","Ignore the question"],correct:1,explanation:"An agent should direct buyers to appropriate sources for information outside real estate expertise.",strategy:"When asked about things outside RE expertise, refer to experts. Agents are not environmental or legal experts."},
{id:193,category:"Test Strategy & Tricky Questions",exam:"both",question:"Which is the BEST description of a 'ready, willing, and able' buyer?",options:["A buyer who has viewed many properties","A buyer who can complete the purchase on the agreed terms, is willing to do so, and is financially qualified","A buyer who has made an offer","A buyer who is pre-qualified but not pre-approved"],correct:1,explanation:"RWA means: Ready (willing to buy now), Willing (wants this property on these terms), and Able (financially qualified to close).",strategy:"RWA = all three: Ready (now), Willing (these terms), Able (financially). Missing any one = not RWA."},
{id:194,category:"Test Strategy & Tricky Questions",exam:"both",question:"A broker is asked to provide a CMA. The broker should explain that a CMA is:",options:["An official appraisal that can be used by lenders","An estimate of value based on comparable sales, not an appraisal","A government-assessed value","A binding price for the seller"],correct:1,explanation:"A CMA estimates market value based on comparable sales but is not a licensed appraisal and cannot be used by lenders.",strategy:"CMA ≠ appraisal. CMA = agent tool for pricing. Appraisal = licensed appraiser, used for lending."},
{id:195,category:"Test Strategy & Tricky Questions",exam:"both",question:"A seller's listing expires and the seller lists with a new broker. The original broker then finds a buyer. Who gets the commission?",options:["The original broker — they found the buyer","The new broker — they have the active listing","Both brokers share the commission","Neither without a signed buyer agreement"],correct:1,explanation:"Once the listing expires, the original broker has no agency relationship. The new broker holds the active listing. Without a carryover clause protecting that buyer's name, the original broker has no claim.",strategy:"Expired listing = no commission right unless a carryover/protection clause names that specific buyer."},
{id:196,category:"Test Strategy & Tricky Questions",exam:"both",question:"A question states 'all of the following are true EXCEPT.' Your strategy is to:",options:["Pick the first answer that looks correct","Find the one statement that is false — that's the answer","Look for the most complex answer","Pick the answer with the most words"],correct:1,explanation:"'All true EXCEPT' means three answers are true and one is false. The false statement is the correct answer.",strategy:"'All true EXCEPT' = find the false statement. Evaluate each: T, T, T, F. The F is your answer."},
{id:197,category:"Test Strategy & Tricky Questions",exam:"both",question:"A buyer's agent shows their client a property that seems overpriced. The agent should:",options:["Refuse to show it","Show it and share their professional opinion of value","Tell the buyer to offer the listing price","Disclose that the seller is desperate to sell"],correct:1,explanation:"A buyer's agent should show requested properties and provide honest professional value guidance.",strategy:"Buyer's agent duty = show what client wants + provide honest professional opinions. Never withhold relevant info."},
{id:198,category:"Test Strategy & Tricky Questions",exam:"both",question:"When pacing yourself through the NY broker exam (100 questions, 2.5 hours), you should allocate approximately:",options:["30 seconds per question","1.5 minutes per question","3 minutes per question","5 minutes per question"],correct:1,explanation:"100 questions ÷ 150 minutes = 1.5 minutes per question.",strategy:"1.5 min/question for broker exam. Don't spend 5 minutes on one hard question — skip it and return."},
{id:199,category:"Test Strategy & Tricky Questions",exam:"both",question:"A question you've been stuck on for 2 minutes has two equally plausible answers. You should:",options:["Keep working until you're certain","Mark your best guess, flag it, and move on — return if time permits","Skip it entirely and leave blank","Ask the proctor for clarification"],correct:1,explanation:"Spending too long on one question hurts your overall score. Make your best guess, flag it, and move on.",strategy:"Time management: 2 minutes max per question. Best guess + flag + move on. Return at the end if time allows."},
{id:200,category:"Test Strategy & Tricky Questions",exam:"both",question:"You finish the exam with 10 minutes remaining. You should:",options:["Submit immediately","Review flagged questions and any you're unsure about","Change most of your answers to improve accuracy","Skip reviewing — your first instinct is always right"],correct:1,explanation:"Use remaining time to review flagged questions. Don't change answers unless you have a clear, specific reason.",strategy:"Review flagged items with remaining time. Change answers only with a specific reason — not just a feeling."},

];

