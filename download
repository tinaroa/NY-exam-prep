export default function App(){
  const [unlocked,setUnlocked]=useState(()=>sessionStorage.getItem("nyreUnlocked")==="1");
  const [tab,setTab]=useState("Dashboard");
  const [examFilter,setExamFilter]=useState("All");

  const unlock=()=>{sessionStorage.setItem("nyreUnlocked","1");setUnlocked(true);};

  if(!unlocked) return <AccessGate onUnlock={unlock} />;

  const filtered=QUESTIONS.filter(q=>{
    if(examFilter==="All") return true;
    if(examFilter==="Broker") return q.exam==="broker"||q.exam==="both";
    return q.exam==="both";
  });
  const filteredFC=FLASHCARDS.filter(f=>{
    if(examFilter==="All") return true;
    if(examFilter==="Broker") return true;
    return true;
  });

  return (
    <div style={{minHeight:"100vh",background:C.bg,fontFamily:"system-ui,sans-serif"}}>
      <NavBar tab={tab} setTab={setTab} examFilter={examFilter} setExamFilter={setExamFilter} />
      {tab==="Dashboard"&&<Dashboard questions={filtered} flashcards={filteredFC} setTab={setTab} />}
      {tab==="Quiz"&&<Quiz questions={filtered} />}
      {tab==="Flashcards"&&<Flashcards flashcards={filteredFC} />}
      {tab==="Study Guide"&&<StudyGuide />}
    </div>
  );
}
